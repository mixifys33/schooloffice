{
  "name": "school-management-system-sms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/pre-dev.js",
    "dev": "next dev",
    "dev:full": "npm run db:generate && npm run db:push && next dev",
    "build": "next build --no-lint",
    "build:direct": "node --max-old-space-size=4096 node_modules/next/dist/bin/next build --no-lint",
    "build:webpack": "next build --webpack --no-lint",
    "build:optimized": "node build-optimize.js && next build --no-lint",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest --run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-permissions.ts",
    "job:health-scores": "ts-node --compiler-options {\"module\":\"CommonJS\"} src/jobs/health-score-calculator.ts",
    "job:scheduler": "ts-node --compiler-options {\"module\":\"CommonJS\"} src/jobs/scheduler.ts",
    "db:check": "node check-database-connection.js",
    "test:api-fixes": "node test-api-fixes.js",
    "verify:dos-fixes": "node verify-dos-fixes.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/jspdf": "^1.3.3",
    "@types/node-cron": "^3.0.11",
    "@vercel/analytics": "^1.6.1",
    "africastalking": "^0.7.9",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "handlebars": "^4.7.8",
    "html2canvas": "^1.4.1",
    "imagekit": "^6.0.0",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.562.0",
    "next": "15.1.9",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^6.9.16",
    "prisma": "^6.19.1",
    "puppeteer": "^24.37.2",
    "react": "^19.0.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.0.1",
    "react-hook-form": "^7.69.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "nodemailer": "^6.9.16"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "fast-check": "^4.5.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.16"
  }
}
