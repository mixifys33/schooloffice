// Financial Report Types
enum FinancialReportType {
  INCOME_STATEMENT
  CASH_FLOW
  BALANCE_SHEET
  FEE_COLLECTION
  BUDGET_VARIANCE
  PAYMENT_ANALYSIS
  OUTSTANDING_FEES
  EXPENSE_SUMMARY
