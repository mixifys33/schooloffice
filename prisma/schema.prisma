  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assessmentPlan AssessmentPlan @relation(fields: [assessmentPlanId], references: [id], onDelete: Cascade)
  results        CAResult[]

  @@index([assessmentPlanId])
  @@index([type])
  @@index([dueDate])
  @@index([schoolId])
}

// CA Results per student
model CAResult {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId               String   @db.ObjectId
  continuousAssessmentId String   @db.ObjectId
  studentId              String   @db.ObjectId
  score                  Float
  maxScore               Float
  percentage             Float // Calculated percentage
  remarks                String?
  enteredBy              String   @db.ObjectId
  enteredAt              DateTime @default(now())
