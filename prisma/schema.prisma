// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  DEPUTY
  TEACHER
  ACCOUNTANT
  STUDENT
  PARENT
  DOS // Director of Studies
}

// Super Admin Control Center - Alert Types
enum AlertType {
  LOW_SMS
  INACTIVE_ADMIN
  PAYMENT_OVERDUE
  CRITICAL_HEALTH
  DECLINING_ENROLLMENT
}

// Super Admin Control Center - Alert Severity
enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// Super Admin Control Center - Action Types
enum ActionType {
  SUSPEND
  REACTIVATE
  CHANGE_PLAN
  RESET_PASSWORD
  FORCE_LOGOUT
  IMPERSONATE
  BULK_SUSPEND
  BULK_REACTIVATE
  BULK_NOTICE
}

enum PilotType {
  FREE
  PAID
}

enum StudentStatus {
  ACTIVE
  TRANSFERRED
  GRADUATED
  SUSPENDED
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum ExamType {
  BOT
  MID
  EOT
  CA
}

// DoS-specific enums
enum AssessmentType {
  TEST
  ASSIGNMENT
  PROJECT
  PRACTICAL
  QUIZ
}

enum GradeDescriptor {
  DISTINCTION
  CREDIT
  PASS
  FAIL
}

enum GradingCategory {
  FINAL // Applied to final marks (Exam + CA)
  EXAM_ONLY // Applied to exam marks only
  CA_ONLY // Applied to CA marks only
}

enum PromotionStatus {
  PROMOTED
  REPEAT
  RETAKE
  PENDING
}

enum ReportCardStatus {
  DRAFT       // Being generated
  GENERATED   // PDF created, awaiting approval
  APPROVED    // DoS approved
  PUBLISHED   // Released to guardians
  REVOKED     // Withdrawn
  LOCKED      // Legacy status (kept for compatibility)
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK
}

enum MessageChannel {
  SMS
  EMAIL
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum MessageType {
  AUTOMATED
  MANUAL
}

enum RelationshipType {
  FATHER
  MOTHER
  GUARDIAN
  UNCLE
  AUNT
  GRANDPARENT
  SPONSOR
  OTHER
}

// Guardian Management - Requirements 6.1, 6.2
enum GuardianStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  RESTRICTED
}

enum GuardianFlag {
  FEE_DEFAULTER
  HIGH_CONFLICT
  LEGAL_RESTRICTION
}

// Guardian Document Types - Requirements 7.1, 7.2
enum GuardianDocumentType {
  CONSENT_FORM
  AGREEMENT
  LEGAL_LETTER
  ID_COPY
  OTHER
}

enum DisciplineType {
  MINOR
  MAJOR
  CRITICAL
}

enum DisciplineAction {
  WARNING
  DETENTION
  SUSPENSION
  EXPULSION
}

enum LicenseType {
  FREE_PILOT
  BASIC
  PREMIUM
}

enum SchoolType {
  PRIMARY
  SECONDARY
  BOTH
}

enum LevelType {
  O_LEVEL
  A_LEVEL
}

enum Ownership {
  PRIVATE
  GOVERNMENT
}

// Account lifecycle status - Requirements 17.3, 17.4, 17.5
enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// Permission types for role-permission mapping - Requirements 19.1, 19.6
enum PermissionType {
  VIEW
  CREATE
  EDIT
  DELETE
  APPROVE
  EXPORT
}

// System lock types - Requirements 20.3, 20.4, 20.5, 20.7
enum LockType {
  TERM_CLOSED
  RESULTS_PUBLISHED
  FINANCIAL_PERIOD_LOCKED
}

// ============================================
// STAFF DASHBOARD ENUMS
// Requirements: 1.4, 3.2, 12.1, 13.1, 14.1
// ============================================

enum StaffRole {
  CLASS_TEACHER
  DOS
  HOSTEL_STAFF
  SUPPORT_STAFF
  BURSAR
}

enum ResponsibilityType {
  CLASS_TEACHING
  SUBJECT_TEACHING
  CLASS_TEACHER_DUTY
  DUTY_TEACHER
  BOARDING_MASTER
  DEPARTMENT_HEAD
}

enum StaffEventType {
  HIRED
  ROLE_ASSIGNED
  ROLE_REMOVED
  PROMOTED
  TRANSFERRED
  RESPONSIBILITY_ASSIGNED
  RESPONSIBILITY_REMOVED
  STATUS_CHANGED
  DEACTIVATED
}

enum TaskType {
  SUBMIT_MARKS
  SUBMIT_REPORT
  COMPLETE_ATTENDANCE
  REVIEW_MARKS
  GENERATE_REPORTS
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
}

enum LinkedModule {
  ACADEMICS
  REPORTS
  ATTENDANCE
  FINANCE
}

enum StaffDocumentCategory {
  CONTRACT
  CERTIFICATION
  EVALUATION
  ID_DOCUMENT
  QUALIFICATION
  OTHER
}

// ============================================
// CORE MODELS
// ============================================

model School {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  code               String      @unique // Immutable tenant identifier
  schoolType         SchoolType  @default(PRIMARY)
  registrationNumber String?
  ownership          Ownership   @default(PRIVATE)
  country            String      @default("Uganda")
  district           String?
  address            String?
  phone              String?
  email              String?
  logo               String?
  licenseType        LicenseType @default(FREE_PILOT)
  features           Json        @default("{\"smsEnabled\":true,\"emailEnabled\":true,\"paymentIntegration\":true}")
  smsBudgetPerTerm   Int         @default(0)
  isActive           Boolean     @default(true)
  termsAcceptedAt    DateTime? // Legal acknowledgment timestamp
  dataAcknowledgedAt DateTime? // Data responsibility acknowledgment timestamp
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Relations
  users            User[]
  students         Student[]
  staff            Staff[]
  teachers         Teacher[]
  academicYears    AcademicYear[]
  classes          Class[]
  subjects         Subject[]
  gradingSystems   GradingSystem[]
  exams            Exam[]
  feeStructures    FeeStructure[]
  messages         Message[]
  messageTemplates MessageTemplate[]
  auditLogs        AuditLog[]
  announcements    Announcement[]
  authAuditLogs    AuthAuditLog[]
  hubAlerts        HubAlert[]
  // Health metrics removed - not needed for core operations
  // healthMetrics    SchoolHealthMetrics?
  alerts           SchoolAlert[]

  // SMS Template System Relations
  customSMSTemplates  CustomSMSTemplate[]
  smsAutomationRules  SMSAutomationRule[]
  smsCreditProtection SMSCreditProtection?
  smsAuditLogs        SMSAuditLog[]

  // New Curriculum Report Card Relations
  reportCardTemplates      ReportCardTemplate[]
  newCurriculumReportCards NewCurriculumReportCard[]

  // DoS Module Relations
  dosCurriculumSubjects DoSCurriculumSubject[]
  dosTimetables         DoSTimetable[]
  curriculumSubjects    CurriculumSubject[]
  timetableConfiguration TimetableConfiguration?

  // Support System Relations
  supportRequests SupportRequest[]

  // Timetable System Relations
  schoolTimeStructures        SchoolTimeStructure[]
  subjectPeriodRequirements   SubjectPeriodRequirement[]
  teacherConstraints          TeacherConstraint[]
  roomConstraints             RoomConstraint[]
  timetableDrafts             TimetableDraft[]
  timetableVersions           TimetableVersion[]
  conflictLogs                TimetableConflictLog[]
  timetableGenerationSettings TimetableGenerationSettings?
  rooms                       Room[]

  // Finance Relations
  studentAccounts StudentAccount[]
  smsLogs         SmsLog[]

  // Competency Relations
  competencies Competency[]

  // Timetable Preferences Relations
  timetablePreferences TimetablePreference[]
  adjustmentPatterns   AdjustmentPattern[]

  // Phase 1 Multi-Tenancy Relations
  guardians        Guardian[]
  terms            Term[]
  streams          Stream[]
  marks            Mark[]
  results          Result[]
  attendances      Attendance[]
  caEntries        CAEntry[]
  examEntries      ExamEntry[]
  disciplineCases  DisciplineCase[]
  studentDocuments StudentDocument[]

  // Phase 2 Multi-Tenancy Relations
  classSubjects            ClassSubject[]
  staffSubjects            StaffSubject[]
  staffClasses             StaffClass[]
  studentGuardians         StudentGuardian[]
  gradeRanges              GradeRange[]
  feeItems                 FeeItem[]
  invoiceItems             InvoiceItem[]
  paymentAllocations       PaymentAllocation[]
  guardianDocuments        GuardianDocument[]
  guardianPortalAccesses   GuardianPortalAccess[]
  guardianAuditLogs        GuardianAuditLog[]
  staffResponsibilities    StaffResponsibility[]
  staffHistoryEntries      StaffHistoryEntry[]
  staffDocuments           StaffDocument[]
  teacherAlerts            TeacherAlert[]
  learningEvidences        LearningEvidence[]
  teacherAssessments       TeacherAssessment[]
  teacherAssessmentResults TeacherAssessmentResult[]
  assessmentPlans          AssessmentPlan[]
  continuousAssessments    ContinuousAssessment[]

  // Phase 3 Multi-Tenancy Relations
  secureLinks                       SecureLink[]
  loginAttempts                     LoginAttempt[]
  shortUrlClicks                    ShortUrlClick[]
  bulkMessageItems                  BulkMessageItem[]
  directMessages                    DirectMessage[]
  automationExecutions              AutomationExecution[]
  announcementDeliveries            AnnouncementDelivery[]
  timetableSlots                    TimetableSlot[]
  timetableConflicts                TimetableConflict[]
  teacherDocuments                  TeacherDocument[]
  teacherHistoryEntries             TeacherHistoryEntry[]
  teacherExaminationRoleAssignments TeacherExaminationRoleAssignment[]
  assignmentSubmissions             AssignmentSubmission[]
  doSAssessmentPlans                DoSAssessmentPlan[]
  doSContinuousAssessments          DoSContinuousAssessment[]
  doSExams                          DoSExam[]
  doSExamResults                    DoSExamResult[]
  doSFinalScores                    DoSFinalScore[]
  doSTimetableEntries               DoSTimetableEntry[]
  dosApprovals                      DosApproval[]
  caResults                         CAResult[]
  competencyProgresses              CompetencyProgress[]
  competencyMappings                CompetencyMapping[]
  competencyAuditTrails             CompetencyAuditTrail[]
  pdfAccesses                       PDFAccess[]
  timetableEntries                  TimetableEntry[]
  studentDiscounts                  StudentDiscount[]
  studentPenalties                  StudentPenalty[]
  studentMilestoneStatuses          StudentMilestoneStatus[]
  
  // Report System Relations
  reportHistory ReportHistory[]
  reportRemarks ReportRemark[]
  
  // Report Card System Relations
  reportCards          ReportCard[]
  reportTemplates      ReportTemplate[]
  reportGenerationLogs ReportGenerationLog[]
  
  // Subject Combination Relations
  combinations         Combination[]
  studentSubjects      StudentSubject[]
  combinationSubjects  CombinationSubject[]
  teacherAssignments   TeacherAssignment[]

  @@index([isActive])
}

// ============================================
// ACADEMIC STRUCTURE
// ============================================

model AcademicYear {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String   @db.ObjectId
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  isCurrent Boolean  @default(false) // Current academic year flag
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms  Term[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([isActive])
}

model Term {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId       String   @db.ObjectId
  academicYearId String   @db.ObjectId
  name           String
  startDate      DateTime
  endDate        DateTime
  weekCount      Int      @default(12)
  isCurrent      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  school            School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear      AcademicYear             @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exams             Exam[]
  results           Result[]
  payments          Payment[]
  feeStructures     FeeStructure[]
  milestoneTrackers StudentMilestoneStatus[]
  studentAccounts   StudentAccount[]

  // DoS Module Relations
  dosAssessmentPlans       DoSAssessmentPlan[]       @relation("DoSAssessmentPlans")
  dosExams                 DoSExam[]
  finalScores              DoSFinalScore[]
  dosTimetables            DoSTimetable[]
  promotionDecisions       DoSPromotionDecision[]
  dosReportCards           DoSReportCard[]
  newCurriculumReportCards NewCurriculumReportCard[]
  assessmentPlans          AssessmentPlan[]

  // Timetable System Relations
  timetableDrafts TimetableDraft[]

  // Class Teacher Marks Management Relations
  caEntries   CAEntry[]
  examEntries ExamEntry[]

  // Competency Relations
  competencyProgress CompetencyProgress[]

  // Grading System Relations
  gradingSystems GradingSystem[]
  
  // Report System Relations
  reportHistory ReportHistory[]
  reportRemarks ReportRemark[]
  
  // Report Card System Relations
  reportCards          ReportCard[]
  reportGenerationLogs ReportGenerationLog[]

  @@unique([academicYearId, name])
  @@index([academicYearId])
  @@index([schoolId])
}

model Class {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String     @db.ObjectId
  name      String
  level     Int
  levelType LevelType? // O_LEVEL or A_LEVEL (optional for flexibility)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  school           School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  streams          Stream[]
  students         Student[]
  classSubjects    ClassSubject[]
  staffSubjects    StaffSubject[]
  timetableEntries TimetableEntry[]
  feeStructures    FeeStructure[]
  attendance       Attendance[]
  staffClasses     StaffClass[]

  // DoS Module Relations
  dosCurriculumSubjects DoSCurriculumSubject[] @relation("DoSCurriculumSubjects")
  dosTimetables         DoSTimetable[]
  dosTimetableEntries   DoSTimetableEntry[] // School-wide timetable entries
  promotionDecisions    DoSPromotionDecision[]
  curriculumSubjects    CurriculumSubject[]
  dosApprovals          DosApproval[]

  // Teacher Section Relations
  learningEvidences  LearningEvidence[]
  teacherAssessments TeacherAssessment[]

  // Timetable System Relations
  subjectPeriodRequirements SubjectPeriodRequirement[]
  timetableSlots            TimetableSlot[]

  // Competency Relations
  competencies Competency[]

  // Grading System Relations
  gradingSystems GradingSystem[]
  
  // Report System Relations
  reportHistory ReportHistory[]
  
  // Report Card System Relations
  reportCards          ReportCard[]
  reportGenerationLogs ReportGenerationLog[]
  
  // Teacher Assignment Relations
  teacherAssignments TeacherAssignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Stream {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String   @db.ObjectId
  classId   String   @db.ObjectId
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class    Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  students Student[]
  dosTimetableEntries DoSTimetableEntry[] // School-wide timetable entries

  @@unique([classId, name])
  @@index([classId])
  @@index([schoolId])
}

model Subject {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  schoolId       String      @db.ObjectId
  name           String      // e.g. Mathematics
  code           String      // e.g. MTC
  educationLevel SchoolType  // PRIMARY or SECONDARY
  levelType      LevelType?  // O_LEVEL or A_LEVEL (for secondary schools)
  isCompulsory   Boolean     @default(true) // Whether subject is compulsory (for O-Level)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  school           School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classSubjects    ClassSubject[]
  staffSubjects    StaffSubject[]
  marks            Mark[]
  timetableEntries TimetableEntry[]

  // DoS Module Relations
  dosCurriculumSubjects DoSCurriculumSubject[] @relation("DoSCurriculumSubjects")
  curriculumSubjects    CurriculumSubject[]
  dosApprovals          DosApproval[]

  // Teacher Section Relations
  learningEvidences  LearningEvidence[]
  teacherAssessments TeacherAssessment[]

  // Timetable System Relations
  subjectPeriodRequirements SubjectPeriodRequirement[]
  timetableSlots            TimetableSlot[]

  // Class Teacher Marks Management Relations
  caEntries   CAEntry[]
  examEntries ExamEntry[]

  // Competency Relations
  competencies Competency[]

  // Timetable Preferences Relations
  timetablePreferences TimetablePreference[]
  adjustmentPatterns   AdjustmentPattern[]
  
  // Report System Relations
  reportHistory ReportHistory[]
  
  // Subject Combination Relations
  teacherAssignments  TeacherAssignment[]
  studentSubjects     StudentSubject[]
  combinationSubjects CombinationSubject[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([isActive])
}

model GradingSystem {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String          @db.ObjectId
  name      String
  category  GradingCategory @default(FINAL)
  isDefault Boolean         @default(false)

  // Optional: Apply to specific class or whole school
  classId String? @db.ObjectId

  // Optional: Tie to specific term
  termId String? @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class  Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)
  term   Term?        @relation(fields: [termId], references: [id], onDelete: Cascade)
  grades GradeRange[]

  @@unique([schoolId, name, category])
  @@index([schoolId])
  @@index([category])
  @@index([isDefault])
  @@index([classId])
  @@index([termId])
}

model GradeRange {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId        String   @db.ObjectId
  gradingSystemId String   @db.ObjectId
  grade           String
  minScore        Float
  maxScore        Float
  points          Float
  remarks         String?
  createdAt       DateTime @default(now())

  // Relations
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradingSystem GradingSystem @relation(fields: [gradingSystemId], references: [id], onDelete: Cascade)

  @@index([gradingSystemId])
  @@index([schoolId])
}

model ClassSubject {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId        String   @db.ObjectId
  classId         String   @db.ObjectId
  subjectId       String   @db.ObjectId
  maxMark         Float    @default(100)
  appearsOnReport Boolean  @default(true)
  affectsPosition Boolean  @default(true)
  isCompulsory    Boolean  @default(true) // Whether subject is compulsory for all students
  minRequired     Int?     // Minimum number required (for O-Level S3/S4 electives)
  createdAt       DateTime @default(now())

  // Relations
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
  @@index([schoolId])
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id                 String        @id @default(auto()) @map("_id") @db.ObjectId
  schoolId           String?       @db.ObjectId // Nullable for Super Admin users
  email              String
  phone              String?
  username           String? // Alternative login identifier
  passwordHash       String?
  role               Role // Primary role (kept for backward compatibility)
  roles              Role[] // Support multiple roles
  activeRole         Role? // Currently active role in session
  isActive           Boolean       @default(true)
  lastLogin          DateTime?
  failedAttempts     Int           @default(0) // For rate limiting
  lockedUntil        DateTime? // Account lockout timestamp
  forcePasswordReset Boolean       @default(false) // Force password change on next login
  // Account lifecycle fields - Requirements 17.3, 17.4, 17.5
  status             AccountStatus @default(ACTIVE)
  deletedAt          DateTime? // Soft delete timestamp
  deletedBy          String?       @db.ObjectId // User who performed the deletion
  suspendedAt        DateTime? // Suspension timestamp
  suspendedBy        String?       @db.ObjectId // User who performed the suspension
  suspendReason      String? // Reason for suspension
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  // Relations
  school        School?        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff         Staff?
  auditLogs     AuditLog[]
  authAuditLogs AuthAuditLog[]

  @@unique([schoolId, email])
  @@unique([schoolId, phone])
  @@unique([schoolId, username])
  @@index([schoolId])
  @@index([email])
  @@index([isActive])
  @@index([status])
}

// ============================================
// ROLE PERMISSIONS - Requirements 19.1, 19.6
// ============================================

model RolePermission {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  role      Role
  feature   String // Feature name (e.g., "students", "marks", "fees")
  type      PermissionType
  createdAt DateTime       @default(now())

  @@unique([role, feature, type])
  @@index([role])
  @@index([feature])
}

// ============================================
// SYSTEM LOCKS - Requirements 20.3, 20.4, 20.5, 20.7
// ============================================

model SystemLock {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId     String    @db.ObjectId
  lockType     LockType
  recordId     String // termId, periodId, etc.
  lockedAt     DateTime  @default(now())
  lockedBy     String    @db.ObjectId // User who created the lock
  unlockedAt   DateTime? // When the lock was removed
  unlockedBy   String?   @db.ObjectId // User who removed the lock
  unlockReason String? // Reason for unlocking (required for audit)

  @@unique([schoolId, lockType, recordId])
  @@index([schoolId])
  @@index([lockType])
  @@index([recordId])
}

// ============================================
// PASSWORD RESET - Requirements 17.1, 17.2
// ============================================

model PasswordReset {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  schoolId  String    @db.ObjectId // School context for verification
  token     String    @unique // Unique reset token
  expiresAt DateTime // Token expiration time
  usedAt    DateTime? // When the token was used
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([schoolId])
  @@index([expiresAt])
}

// ============================================
// STUDENT & GUARDIAN
// ============================================

model Student {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  schoolId        String        @db.ObjectId
  admissionNumber String
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  gender          Gender?
  classId         String        @db.ObjectId
  streamId        String?       @db.ObjectId
  combinationId   String?       @db.ObjectId // For A-Level subject combinations
  pilotType       PilotType     @default(FREE)
  smsLimitPerTerm Int           @default(2)
  smsSentCount    Int           @default(0)
  photo           String?
  medicalInfo     String?
  enrollmentDate  DateTime      @default(now())
  status          StudentStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  school            School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class             Class                    @relation(fields: [classId], references: [id])
  stream            Stream?                  @relation(fields: [streamId], references: [id])
  combination       Combination?             @relation(fields: [combinationId], references: [id])
  studentGuardians  StudentGuardian[]
  attendance        Attendance[]
  marks             Mark[]
  results           Result[]
  payments          Payment[]
  messages          Message[]
  disciplineCases   DisciplineCase[]
  documents         StudentDocument[]
  milestoneTrackers StudentMilestoneStatus[]
  studentAccounts   StudentAccount[]
  smsLogs           SmsLog[]

  // DoS Module Relations
  continuousAssessments    DoSContinuousAssessment[]
  dosExamResults           DoSExamResult[]
  finalScores              DoSFinalScore[]
  dosReportCards           DoSReportCard[]
  newCurriculumReportCards NewCurriculumReportCard[]
  promotionDecisions       DoSPromotionDecision[]
  caResults                CAResult[]

  // Teacher Section Relations
  teacherAssessmentResults TeacherAssessmentResult[]
  learningEvidences        LearningEvidence[]

  // Class Teacher Marks Management Relations
  caEntries   CAEntry[]
  examEntries ExamEntry[]

  // Competency Relations
  competencyProgress   CompetencyProgress[]
  competencyAuditTrail CompetencyAuditTrail[]
  
  // Report System Relations
  reportHistory ReportHistory[]
  reportRemarks ReportRemark[]
  
  // Report Card System Relations
  reportCards ReportCard[]
  
  // Subject Selection Relations
  studentSubjects StudentSubject[]

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([classId])
  @@index([streamId])
  @@index([combinationId])
  @@index([status])
}

model Guardian {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  schoolId           String           @db.ObjectId
  firstName          String
  lastName           String
  phone              String
