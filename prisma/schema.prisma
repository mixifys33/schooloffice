// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  SUPER_ADMIN
  SCHOOL_ADMIN
  DEPUTY
  TEACHER
  ACCOUNTANT
  STUDENT
  PARENT
}

enum PilotType {
  FREE
  PAID
}

enum StudentStatus {
  ACTIVE
  TRANSFERRED
  GRADUATED
  SUSPENDED
}

enum StaffStatus {
  ACTIVE
  INACTIVE
}

enum Gender {
  MALE
  FEMALE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum ExamType {
  BOT
  MID
  EOT
  CA
}

enum PaymentMethod {
  CASH
  MOBILE_MONEY
  BANK
}

enum MessageChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  READ
}

enum RelationshipType {
  FATHER
  MOTHER
  GUARDIAN
  UNCLE
  AUNT
  GRANDPARENT
  SPONSOR
  OTHER
}

// Guardian Management - Requirements 6.1, 6.2
enum GuardianStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  RESTRICTED
}

enum GuardianFlag {
  FEE_DEFAULTER
  HIGH_CONFLICT
  LEGAL_RESTRICTION
}

// Guardian Document Types - Requirements 7.1, 7.2
enum GuardianDocumentType {
  CONSENT_FORM
  AGREEMENT
  LEGAL_LETTER
  ID_COPY
  OTHER
}

enum DisciplineType {
  MINOR
  MAJOR
  CRITICAL
}

enum DisciplineAction {
  WARNING
  DETENTION
  SUSPENSION
  EXPULSION
}

enum LicenseType {
  FREE_PILOT
  BASIC
  PREMIUM
}

enum SchoolType {
  PRIMARY
  SECONDARY
  BOTH
}

enum Ownership {
  PRIVATE
  GOVERNMENT
}

// Account lifecycle status - Requirements 17.3, 17.4, 17.5
enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// Permission types for role-permission mapping - Requirements 19.1, 19.6
enum PermissionType {
  VIEW
  CREATE
  EDIT
  DELETE
  APPROVE
  EXPORT
}

// System lock types - Requirements 20.3, 20.4, 20.5, 20.7
enum LockType {
  TERM_CLOSED
  RESULTS_PUBLISHED
  FINANCIAL_PERIOD_LOCKED
}

// ============================================
// STAFF DASHBOARD ENUMS
// Requirements: 1.4, 3.2, 12.1, 13.1, 14.1
// ============================================

enum StaffRole {
  CLASS_TEACHER
  DOS
  HOSTEL_STAFF
  SUPPORT_STAFF
  BURSAR
}

enum ResponsibilityType {
  CLASS_TEACHING
  SUBJECT_TEACHING
  CLASS_TEACHER_DUTY
  DUTY_TEACHER
  BOARDING_MASTER
  DEPARTMENT_HEAD
}

enum StaffEventType {
  HIRED
  ROLE_ASSIGNED
  ROLE_REMOVED
  PROMOTED
  TRANSFERRED
  RESPONSIBILITY_ASSIGNED
  RESPONSIBILITY_REMOVED
  STATUS_CHANGED
  DEACTIVATED
}

enum TaskType {
  SUBMIT_MARKS
  SUBMIT_REPORT
  COMPLETE_ATTENDANCE
  REVIEW_MARKS
  GENERATE_REPORTS
}

enum TaskStatus {
  PENDING
  COMPLETED
  OVERDUE
}

enum LinkedModule {
  ACADEMICS
  REPORTS
  ATTENDANCE
  FINANCE
}

enum StaffDocumentCategory {
  CONTRACT
  CERTIFICATION
  EVALUATION
  ID_DOCUMENT
  QUALIFICATION
  OTHER
}

// ============================================
// CORE MODELS
// ============================================

model School {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  name               String
  code               String      @unique // Immutable tenant identifier
  schoolType         SchoolType  @default(PRIMARY)
  registrationNumber String?
  ownership          Ownership   @default(PRIVATE)
  country            String      @default("Uganda")
  district           String?
  address            String?
  phone              String?
  email              String?
  logo               String?
  licenseType        LicenseType @default(FREE_PILOT)
  features           Json        @default("{\"smsEnabled\":false,\"whatsappEnabled\":false,\"paymentIntegration\":false,\"advancedReporting\":false,\"bulkMessaging\":false}")
  smsBudgetPerTerm   Int         @default(0)
  isActive           Boolean     @default(true)
  termsAcceptedAt    DateTime? // Legal acknowledgment timestamp
  dataAcknowledgedAt DateTime? // Data responsibility acknowledgment timestamp
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Relations
  users            User[]
  students         Student[]
  staff            Staff[]
  teachers         Teacher[]
  academicYears    AcademicYear[]
  classes          Class[]
  subjects         Subject[]
  gradingSystems   GradingSystem[]
  exams            Exam[]
  feeStructures    FeeStructure[]
  messages         Message[]
  messageTemplates MessageTemplate[]
  auditLogs        AuditLog[]
  announcements    Announcement[]
  authAuditLogs    AuthAuditLog[]
  hubAlerts        HubAlert[]

  @@index([isActive])
}

// ============================================
// ACADEMIC STRUCTURE
// ============================================

model AcademicYear {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String   @db.ObjectId
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms  Term[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([isActive])
}

model Term {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  academicYearId String   @db.ObjectId
  name           String
  startDate      DateTime
  endDate        DateTime
  weekCount      Int      @default(12)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  academicYear  AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exams         Exam[]
  results       Result[]
  payments      Payment[]
  feeStructures FeeStructure[]

  @@unique([academicYearId, name])
  @@index([academicYearId])
}

model Class {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String   @db.ObjectId
  name      String
  level     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school           School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  streams          Stream[]
  students         Student[]
  classSubjects    ClassSubject[]
  timetableEntries TimetableEntry[]
  feeStructures    FeeStructure[]
  attendance       Attendance[]
  staffClasses     StaffClass[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Stream {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  classId   String   @db.ObjectId
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  class    Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([classId, name])
  @@index([classId])
}

model Subject {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId        String   @db.ObjectId
  name            String
  code            String
  gradingSystemId String?  @db.ObjectId
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  school           School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradingSystem    GradingSystem?   @relation(fields: [gradingSystemId], references: [id])
  classSubjects    ClassSubject[]
  staffSubjects    StaffSubject[]
  marks            Mark[]
  timetableEntries TimetableEntry[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([gradingSystemId])
}

model GradingSystem {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String   @db.ObjectId
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school   School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  grades   GradeRange[]
  subjects Subject[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model GradeRange {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  gradingSystemId String   @db.ObjectId
  grade           String
  minScore        Float
  maxScore        Float
  points          Float
  remarks         String?
  createdAt       DateTime @default(now())

  // Relations
  gradingSystem GradingSystem @relation(fields: [gradingSystemId], references: [id], onDelete: Cascade)

  @@index([gradingSystemId])
}

model ClassSubject {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  classId   String   @db.ObjectId
  subjectId String   @db.ObjectId
  createdAt DateTime @default(now())

  // Relations
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
  @@index([classId])
  @@index([subjectId])
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  schoolId       String?       @db.ObjectId // Nullable for Super Admin users
  email          String
  phone          String?
  username       String? // Alternative login identifier
  passwordHash   String?
  role           Role // Primary role (kept for backward compatibility)
  roles          Role[] // Support multiple roles
  activeRole     Role? // Currently active role in session
  isActive       Boolean       @default(true)
  lastLogin      DateTime?
  failedAttempts Int           @default(0) // For rate limiting
  lockedUntil    DateTime? // Account lockout timestamp
  forcePasswordReset Boolean   @default(false) // Force password change on next login
  // Account lifecycle fields - Requirements 17.3, 17.4, 17.5
  status         AccountStatus @default(ACTIVE)
  deletedAt      DateTime? // Soft delete timestamp
  deletedBy      String?       @db.ObjectId // User who performed the deletion
  suspendedAt    DateTime? // Suspension timestamp
  suspendedBy    String?       @db.ObjectId // User who performed the suspension
  suspendReason  String? // Reason for suspension
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  school        School?        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff         Staff?
  auditLogs     AuditLog[]
  authAuditLogs AuthAuditLog[]

  @@unique([schoolId, email])
  @@unique([schoolId, phone])
  @@unique([schoolId, username])
  @@index([schoolId])
  @@index([email])
  @@index([isActive])
  @@index([status])
}

// ============================================
// ROLE PERMISSIONS - Requirements 19.1, 19.6
// ============================================

model RolePermission {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  role      Role
  feature   String // Feature name (e.g., "students", "marks", "fees")
  type      PermissionType
  createdAt DateTime       @default(now())

  @@unique([role, feature, type])
  @@index([role])
  @@index([feature])
}

// ============================================
// SYSTEM LOCKS - Requirements 20.3, 20.4, 20.5, 20.7
// ============================================

model SystemLock {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId     String    @db.ObjectId
  lockType     LockType
  recordId     String // termId, periodId, etc.
  lockedAt     DateTime  @default(now())
  lockedBy     String    @db.ObjectId // User who created the lock
  unlockedAt   DateTime? // When the lock was removed
  unlockedBy   String?   @db.ObjectId // User who removed the lock
  unlockReason String? // Reason for unlocking (required for audit)

  @@unique([schoolId, lockType, recordId])
  @@index([schoolId])
  @@index([lockType])
  @@index([recordId])
}

// ============================================
// PASSWORD RESET - Requirements 17.1, 17.2
// ============================================

model PasswordReset {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  userId    String    @db.ObjectId
  schoolId  String    @db.ObjectId // School context for verification
  token     String    @unique // Unique reset token
  expiresAt DateTime // Token expiration time
  usedAt    DateTime? // When the token was used
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([schoolId])
  @@index([expiresAt])
}

// ============================================
// STUDENT & GUARDIAN
// ============================================

model Student {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  schoolId        String        @db.ObjectId
  admissionNumber String
  firstName       String
  lastName        String
  dateOfBirth     DateTime?
  gender          Gender?
  classId         String        @db.ObjectId
  streamId        String?       @db.ObjectId
  pilotType       PilotType     @default(FREE)
  smsLimitPerTerm Int           @default(2)
  smsSentCount    Int           @default(0)
  photo           String?
  medicalInfo     String?
  enrollmentDate  DateTime      @default(now())
  status          StudentStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  school           School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class            Class             @relation(fields: [classId], references: [id])
  stream           Stream?           @relation(fields: [streamId], references: [id])
  studentGuardians StudentGuardian[]
  attendance       Attendance[]
  marks            Mark[]
  results          Result[]
  payments         Payment[]
  messages         Message[]
  disciplineCases  DisciplineCase[]
  documents        StudentDocument[]
  account          StudentAccount?

  @@unique([schoolId, admissionNumber])
  @@index([schoolId])
  @@index([classId])
  @@index([streamId])
  @@index([status])
}

model Guardian {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  firstName          String
  lastName           String
  phone              String
  secondaryPhone     String?
  phoneVerified      Boolean          @default(false)
  email              String?
  emailVerified      Boolean          @default(false)
  whatsappNumber     String?
  nationalId         String?
  address            String?
  relationship       RelationshipType @default(GUARDIAN)
  preferredChannel   MessageChannel   @default(SMS)
  languagePreference String           @default("en")
  status             GuardianStatus   @default(ACTIVE)
  flags              GuardianFlag[]
  optOutNonCritical  Boolean          @default(false)
  lastContactDate    DateTime?
  consentGiven       Boolean          @default(false)
  consentDate        DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relations
  studentGuardians StudentGuardian[]
  messages         Message[]
  secureLinks      SecureLink[]
  otpVerifications OTPVerification[]
  documents        GuardianDocument[]
  portalAccess     GuardianPortalAccess?
  auditLogs        GuardianAuditLog[]

  @@index([phone])
  @@index([email])
  @@index([status])
}

// Guardian Document - Requirements 7.1, 7.2, 7.3
model GuardianDocument {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  guardianId   String               @db.ObjectId
  documentType GuardianDocumentType
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  uploadedBy   String               @db.ObjectId
  uploadedAt   DateTime             @default(now())

  // Relations
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@index([guardianId])
}

// Guardian Portal Access - Requirements 5.1, 5.2
model GuardianPortalAccess {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  guardianId         String    @unique @db.ObjectId
  isEnabled          Boolean   @default(false)
  canViewAttendance  Boolean   @default(true)
  canViewResults     Boolean   @default(true)
  canViewFees        Boolean   @default(true)
  canDownloadReports Boolean   @default(false)
  passwordHash       String?
  lastLogin          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
}

// Guardian Audit Log - Requirements 5.5, 6.5
model GuardianAuditLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  guardianId    String   @db.ObjectId
  action        String
  field         String?
  previousValue String?
  newValue      String?
  performedBy   String   @db.ObjectId
  performedAt   DateTime @default(now())
  ipAddress     String?

  // Relations
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@index([guardianId])
  @@index([performedAt])
}

model StudentGuardian {
  id                       String           @id @default(auto()) @map("_id") @db.ObjectId
  studentId                String           @db.ObjectId
  guardianId               String           @db.ObjectId
  relationshipType         RelationshipType @default(GUARDIAN)
  isPrimary                Boolean          @default(false)
  isFinanciallyResponsible Boolean          @default(false)
  receivesAcademicMessages Boolean          @default(true)
  receivesFinanceMessages  Boolean          @default(true)
  createdAt                DateTime         @default(now())

  // Relations
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@index([studentId])
  @@index([guardianId])
}

// ============================================
// STAFF
// ============================================

model Staff {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  userId         String      @unique @db.ObjectId
  schoolId       String      @db.ObjectId
  employeeNumber String
  firstName      String
  lastName       String
  phone          String?
  email          String?
  role           Role
  hireDate       DateTime    @default(now())
  status         StaffStatus @default(ACTIVE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Staff Dashboard fields - Requirements 2.3, 3.2
  primaryRole    StaffRole? // Primary dashboard role (CLASS_TEACHER, DOS, HOSTEL_STAFF, SUPPORT_STAFF, BURSAR)
  secondaryRoles StaffRole[] // Additional roles for role switcher
  department     String? // Department assignment
  lastActivityAt DateTime? // Last system activity timestamp

  // Relations
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  school           School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staffSubjects    StaffSubject[]
  staffClasses     StaffClass[]
  marks            Mark[]
  timetableEntries TimetableEntry[]
  disciplineCases  DisciplineCase[]
  attendance       Attendance[]
  responsibilities StaffResponsibility[]
  historyEntries   StaffHistoryEntry[]
  documents        StaffDocument[]
  tasks            StaffTask[]

  @@unique([schoolId, employeeNumber])
  @@index([schoolId])
  @@index([primaryRole])
  @@index([status])
}

model StaffSubject {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  staffId   String   @db.ObjectId
  subjectId String   @db.ObjectId
  createdAt DateTime @default(now())

  // Relations
  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([staffId, subjectId])
  @@index([staffId])
  @@index([subjectId])
}

model StaffClass {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  staffId   String   @db.ObjectId
  classId   String   @db.ObjectId
  createdAt DateTime @default(now())

  // Relations
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([staffId, classId])
  @@index([staffId])
  @@index([classId])
}

// ============================================
// STAFF DASHBOARD MODELS
// Requirements: 2.3, 3.2, 3.4, 12.1, 12.2, 13.1, 14.1
// ============================================

// Staff Responsibility - tracks specific duties assigned to staff
// Requirements: 3.4 - Responsibility assignment separate from permissions
model StaffResponsibility {
  id         String             @id @default(auto()) @map("_id") @db.ObjectId
  staffId    String             @db.ObjectId
  type       ResponsibilityType
  details    Json // Flexible storage for responsibility-specific details (classes, subjects, duty days)
  assignedAt DateTime           @default(now())
  assignedBy String             @db.ObjectId
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  // Relations
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([type])
}

// Staff History Entry - tracks promotions, role changes, transfers, exits
// Requirements: 13.1 - Staff history tracking
model StaffHistoryEntry {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  staffId       String         @db.ObjectId
  eventType     StaffEventType
  previousValue String? // Previous state (e.g., old role, old department)
  newValue      String? // New state (e.g., new role, new department)
  reason        String? // Reason for the change
  performedBy   String         @db.ObjectId // User who made the change
  performedAt   DateTime       @default(now())
  createdAt     DateTime       @default(now())

  // Relations
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([eventType])
  @@index([performedAt])
}

// Staff Document - stores staff documents with categorization
// Requirements: 14.1 - Document storage with categorization
model StaffDocument {
  id         String                @id @default(auto()) @map("_id") @db.ObjectId
  staffId    String                @db.ObjectId
  category   StaffDocumentCategory
  fileName   String
  fileUrl    String
  fileSize   Int?
  mimeType   String?
  uploadedBy String                @db.ObjectId
  uploadedAt DateTime              @default(now())
  createdAt  DateTime              @default(now())

  // Relations
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([category])
}

// Staff Task - tracks tasks assigned to staff members
// Requirements: 12.1, 12.2 - Task management with status and module linking
model StaffTask {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  staffId          String       @db.ObjectId
  schoolId         String       @db.ObjectId
  title            String
  description      String?
  type             TaskType
  linkedModule     LinkedModule
  linkedResourceId String?      @db.ObjectId // Reference to specific resource (exam, report, etc.)
  deadline         DateTime
  status           TaskStatus   @default(PENDING)
  completedAt      DateTime?
  createdBy        String       @db.ObjectId
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  staff Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([schoolId])
  @@index([status])
  @@index([deadline])
  @@index([type])
  @@index([linkedModule])
}

// ============================================
// ATTENDANCE
// ============================================

model Attendance {
  id         String           @id @default(auto()) @map("_id") @db.ObjectId
  studentId  String           @db.ObjectId
  classId    String           @db.ObjectId
  date       DateTime
  period     Int
  status     AttendanceStatus
  recordedBy String           @db.ObjectId
  recordedAt DateTime
  remarks    String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  // Relations
  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class    Class   @relation(fields: [classId], references: [id])
  recorder Staff   @relation(fields: [recordedBy], references: [id])

  @@unique([studentId, date, period])
  @@index([studentId])
  @@index([classId])
  @@index([date])
  @@index([recordedBy])
}

// ============================================
// TIMETABLE
// ============================================

model TimetableEntry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  classId   String   @db.ObjectId
  subjectId String   @db.ObjectId
  staffId   String   @db.ObjectId
  dayOfWeek Int // 1-7 (Monday-Sunday)
  period    Int
  room      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])
  staff   Staff   @relation(fields: [staffId], references: [id])

  @@unique([classId, dayOfWeek, period])
  @@unique([staffId, dayOfWeek, period])
  @@index([classId])
  @@index([staffId])
  @@index([subjectId])
}

// ============================================
// EXAMINATION
// ============================================

model Exam {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String    @db.ObjectId
  termId    String    @db.ObjectId
  name      String
  type      ExamType
  startDate DateTime?
  endDate   DateTime?
  isOpen    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term   Term   @relation(fields: [termId], references: [id])
  marks  Mark[]

  @@index([schoolId])
  @@index([termId])
}

model Mark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  examId    String   @db.ObjectId
  studentId String   @db.ObjectId
  subjectId String   @db.ObjectId
  score     Float
  maxScore  Float
  grade     String?
  enteredBy String   @db.ObjectId
  enteredAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  staff   Staff   @relation(fields: [enteredBy], references: [id])

  @@unique([examId, studentId, subjectId])
  @@index([examId])
  @@index([studentId])
  @@index([subjectId])
  @@index([enteredBy])
}

model Result {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId          String   @db.ObjectId
  termId             String   @db.ObjectId
  totalMarks         Float
  average            Float
  position           Int
  totalStudents      Int?
  grade              String?
  teacherRemarks     String?
  headTeacherRemarks String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  student             Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term                Term                 @relation(fields: [termId], references: [id])
  publishedReportCard PublishedReportCard?

  @@unique([studentId, termId])
  @@index([studentId])
  @@index([termId])
}

// ============================================
// PUBLISHED REPORT CARDS
// ============================================

model PublishedReportCard {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  resultId     String   @unique @db.ObjectId
  studentId    String   @db.ObjectId
  termId       String   @db.ObjectId
  schoolId     String   @db.ObjectId
  publishedBy  String   @db.ObjectId
  publishedAt  DateTime @default(now())
  htmlContent  String? // Cached HTML content for quick access
  isAccessible Boolean  @default(true) // Can be toggled to revoke access

  // Relations
  result Result @relation(fields: [resultId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([termId])
  @@index([schoolId])
  @@index([publishedAt])
}

// ============================================
// FINANCE
// ============================================

// Fee Category Types
enum FeeCategory {
  TUITION
  BOARDING
  TRANSPORT
  MEALS
  UNIFORM
  BOOKS
  EXAMINATION
  ACTIVITY
  OTHER
}

// Student Type for fee differentiation
enum StudentType {
  DAY
  BOARDING
}

// Discount Types
enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// Discount Approval Status
enum DiscountStatus {
  PENDING
  APPROVED
  REJECTED
}

// Invoice Status
enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

// Payment Status for tracking
enum PaymentRecordStatus {
  PENDING
  CONFIRMED
  REVERSED
  CANCELLED
}

model FeeStructure {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String      @db.ObjectId
  classId     String      @db.ObjectId
  termId      String      @db.ObjectId
  studentType StudentType @default(DAY)
  totalAmount Float
  dueDate     DateTime?
  isActive    Boolean     @default(true)
  createdBy   String      @db.ObjectId
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class    Class     @relation(fields: [classId], references: [id])
  term     Term      @relation(fields: [termId], references: [id])
  items    FeeItem[]
  invoices Invoice[]

  @@unique([schoolId, classId, termId, studentType])
  @@index([schoolId])
  @@index([classId])
  @@index([termId])
  @@index([isActive])
}

model FeeItem {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  feeStructureId String      @db.ObjectId
  name           String
  category       FeeCategory @default(OTHER)
  amount         Float
  isOptional     Boolean     @default(false)
  isOneTime      Boolean     @default(false)
  description    String?
  createdAt      DateTime    @default(now())

  // Relations
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@index([feeStructureId])
  @@index([category])
}

// Student Account - tracks individual student financial status
model StudentAccount {
  id                String      @id @default(auto()) @map("_id") @db.ObjectId
  studentId         String      @unique @db.ObjectId
  schoolId          String      @db.ObjectId
  studentType       StudentType @default(DAY)
  totalFees         Float       @default(0)
  totalPaid         Float       @default(0)
  totalDiscounts    Float       @default(0)
  totalPenalties    Float       @default(0)
  balance           Float       @default(0) // totalFees - totalPaid - totalDiscounts + totalPenalties
  lastPaymentDate   DateTime?
  lastPaymentAmount Float?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Relations
  student   Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  discounts StudentDiscount[]
  penalties StudentPenalty[]

  @@unique([studentId, schoolId])
  @@index([schoolId])
  @@index([balance])
}

// Discount definitions (school-wide discount rules)
model DiscountRule {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  schoolId         String       @db.ObjectId
  name             String
  description      String?
  type             DiscountType
  value            Float // Percentage or fixed amount
  maxAmount        Float? // Cap for percentage discounts
  isActive         Boolean      @default(true)
  requiresApproval Boolean      @default(true)
  createdBy        String       @db.ObjectId
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Relations
  studentDiscounts StudentDiscount[]

  @@index([schoolId])
  @@index([isActive])
}

// Student-specific discounts
model StudentDiscount {
  id               String         @id @default(auto()) @map("_id") @db.ObjectId
  studentAccountId String         @db.ObjectId
  discountRuleId   String?        @db.ObjectId
  termId           String         @db.ObjectId
  name             String
  type             DiscountType
  value            Float
  calculatedAmount Float
  reason           String?
  status           DiscountStatus @default(PENDING)
  appliedBy        String         @db.ObjectId
  appliedAt        DateTime       @default(now())
  approvedBy       String?        @db.ObjectId
  approvedAt       DateTime?
  rejectedBy       String?        @db.ObjectId
  rejectedAt       DateTime?
  rejectionReason  String?

  // Relations
  studentAccount StudentAccount @relation(fields: [studentAccountId], references: [id], onDelete: Cascade)
  discountRule   DiscountRule?  @relation(fields: [discountRuleId], references: [id])

  @@index([studentAccountId])
  @@index([termId])
  @@index([status])
}

// Penalty definitions (school-wide penalty rules)
model PenaltyRule {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  schoolId        String       @db.ObjectId
  name            String
  description     String?
  type            DiscountType // PERCENTAGE or FIXED_AMOUNT
  value           Float
  gracePeriodDays Int          @default(0)
  isAutomatic     Boolean      @default(false)
  isActive        Boolean      @default(true)
  createdBy       String       @db.ObjectId
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  studentPenalties StudentPenalty[]

  @@index([schoolId])
  @@index([isActive])
}

// Student-specific penalties
model StudentPenalty {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  studentAccountId String    @db.ObjectId
  penaltyRuleId    String?   @db.ObjectId
  termId           String    @db.ObjectId
  name             String
  amount           Float
  reason           String?
  isWaived         Boolean   @default(false)
  waivedBy         String?   @db.ObjectId
  waivedAt         DateTime?
  waiverReason     String?
  appliedBy        String    @db.ObjectId
  appliedAt        DateTime  @default(now())

  // Relations
  studentAccount StudentAccount @relation(fields: [studentAccountId], references: [id], onDelete: Cascade)
  penaltyRule    PenaltyRule?   @relation(fields: [penaltyRuleId], references: [id])

  @@index([studentAccountId])
  @@index([termId])
  @@index([isWaived])
}

// Invoice for students
model Invoice {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber  String        @unique
  schoolId       String        @db.ObjectId
  studentId      String        @db.ObjectId
  guardianId     String?       @db.ObjectId
  feeStructureId String        @db.ObjectId
  termId         String        @db.ObjectId
  subtotal       Float
  discountAmount Float         @default(0)
  penaltyAmount  Float         @default(0)
  totalAmount    Float
  paidAmount     Float         @default(0)
  balance        Float
  dueDate        DateTime
  status         InvoiceStatus @default(DRAFT)
  notes          String?
  issuedAt       DateTime?
  issuedBy       String?       @db.ObjectId
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  feeStructure FeeStructure        @relation(fields: [feeStructureId], references: [id])
  items        InvoiceItem[]
  payments     PaymentAllocation[]

  @@index([schoolId])
  @@index([studentId])
  @@index([guardianId])
  @@index([termId])
  @@index([status])
  @@index([dueDate])
}

// Invoice line items
model InvoiceItem {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  invoiceId   String      @db.ObjectId
  description String
  category    FeeCategory
  amount      Float
  isOptional  Boolean     @default(false)
  createdAt   DateTime    @default(now())

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// Enhanced Payment model
model Payment {
  id             String              @id @default(auto()) @map("_id") @db.ObjectId
  schoolId       String              @db.ObjectId
  studentId      String              @db.ObjectId
  guardianId     String?             @db.ObjectId // Who paid
  termId         String              @db.ObjectId
  amount         Float
  method         PaymentMethod
  reference      String // Transaction reference
  bankName       String? // For bank/cheque payments
  chequeNumber   String? // For cheque payments
  mobileNumber   String? // For mobile money
  notes          String?
  status         PaymentRecordStatus @default(CONFIRMED)
  receivedBy     String              @db.ObjectId
  receivedAt     DateTime
  receiptId      String?             @db.ObjectId
  reversedBy     String?             @db.ObjectId
  reversedAt     DateTime?
  reversalReason String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  // Relations
  student     Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term        Term                @relation(fields: [termId], references: [id])
  receipt     Receipt?            @relation(fields: [receiptId], references: [id])
  allocations PaymentAllocation[]

  @@index([schoolId])
  @@index([studentId])
  @@index([guardianId])
  @@index([termId])
  @@index([status])
  @@index([receivedAt])
  @@index([method])
}

// Payment allocation to invoices (supports partial payments)
model PaymentAllocation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  paymentId   String   @db.ObjectId
  invoiceId   String   @db.ObjectId
  amount      Float
  allocatedAt DateTime @default(now())

  // Relations
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([paymentId])
  @@index([invoiceId])
}

// Immutable Receipt
model Receipt {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  receiptNumber String        @unique
  schoolId      String        @db.ObjectId
  studentId     String        @db.ObjectId
  guardianId    String?       @db.ObjectId
  studentName   String // Snapshot at time of receipt
  guardianName  String? // Snapshot at time of receipt
  className     String // Snapshot at time of receipt
  termName      String // Snapshot at time of receipt
  amount        Float
  amountInWords String
  method        PaymentMethod
  reference     String
  balanceBefore Float
  balanceAfter  Float
  issuedBy      String        @db.ObjectId
  issuedByName  String // Snapshot
  issuedAt      DateTime      @default(now())
  // Receipts are immutable - no updatedAt

  // Relations
  payments Payment[]

  @@index([schoolId])
  @@index([studentId])
  @@index([guardianId])
  @@index([issuedAt])
}

// Finance Audit Log - specific to finance operations
model FinanceAuditLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId      String   @db.ObjectId
  userId        String   @db.ObjectId
  action        String // PAYMENT_RECORDED, PAYMENT_REVERSED, DISCOUNT_APPLIED, etc.
  resourceType  String // Payment, Invoice, Receipt, Discount, Penalty
  resourceId    String   @db.ObjectId
  previousValue Json?
  newValue      Json?
  reason        String? // Required for reversals/edits
  ipAddress     String?
  timestamp     DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([resourceType])
  @@index([resourceId])
  @@index([timestamp])
  @@index([action])
}

// Finance Notification Log - tracks all finance-related notifications
// Requirements: 8.1, 8.2, 8.3, 8.4, 8.5
model FinanceNotificationLog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String    @db.ObjectId
  guardianId  String    @db.ObjectId
  studentId   String?   @db.ObjectId
  type        String // PAYMENT_CONFIRMATION, FEE_REMINDER, PENALTY_NOTICE, BALANCE_SUMMARY
  channel     String // SMS, WHATSAPP, EMAIL
  content     String
  status      String // QUEUED, SENT, DELIVERED, FAILED, BOUNCED
  sentAt      DateTime?
  deliveredAt DateTime?
  error       String?
  metadata    String? // JSON string with additional data
  createdAt   DateTime  @default(now())

  @@index([schoolId])
  @@index([guardianId])
  @@index([studentId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// Finance Settings per school
model FinanceSettings {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId               String   @unique @db.ObjectId
  currency               String   @default("UGX")
  currencySymbol         String   @default("UGX")
  receiptPrefix          String   @default("RCP")
  invoicePrefix          String   @default("INV")
  receiptNumberFormat    String   @default("{PREFIX}-{YEAR}-{NUMBER}")
  invoiceNumberFormat    String   @default("{PREFIX}-{YEAR}-{NUMBER}")
  nextReceiptNumber      Int      @default(1)
  nextInvoiceNumber      Int      @default(1)
  paymentMethods         String[] @default(["CASH", "MOBILE_MONEY", "BANK"])
  defaultDueDays         Int      @default(30)
  enableAutoPenalty      Boolean  @default(false)
  latePenaltyPercentage  Float    @default(0)
  gracePeriodDays        Int      @default(7)
  enableDiscountApproval Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ============================================
// COMMUNICATION
// ============================================

model Message {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  schoolId     String         @db.ObjectId
  studentId    String         @db.ObjectId
  guardianId   String         @db.ObjectId
  templateType String
  channel      MessageChannel
  content      String
  shortUrl     String?
  status       MessageStatus  @default(QUEUED)
  cost         Float?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  retryCount   Int            @default(0)
  errorMessage String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  school   School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id])
  guardian Guardian @relation(fields: [guardianId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([guardianId])
  @@index([status])
}

model MessageTemplate {
  id        String         @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String         @db.ObjectId
  type      String
  channel   MessageChannel
  content   String
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, type, channel])
  @@index([schoolId])
}

// ============================================
// SECURE LINKS
// ============================================

model SecureLink {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  token        String    @unique
  guardianId   String    @db.ObjectId
  resourceType String
  resourceId   String
  expiresAt    DateTime
  accessedAt   DateTime?
  accessIp     String?
  createdAt    DateTime  @default(now())

  // Relations
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@index([guardianId])
  @@index([expiresAt])
}

// ============================================
// DISCIPLINE
// ============================================

model DisciplineCase {
  id                 String           @id @default(auto()) @map("_id") @db.ObjectId
  studentId          String           @db.ObjectId
  reportedBy         String           @db.ObjectId
  incidentDate       DateTime
  description        String
  type               DisciplineType
  action             DisciplineAction
  actionDuration     Int?
  parentNotified     Boolean          @default(false)
  parentAcknowledged Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  // Relations
  student  Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reporter Staff   @relation(fields: [reportedBy], references: [id])

  @@index([studentId])
  @@index([reportedBy])
}

// ============================================
// ANNOUNCEMENTS
// ============================================

model Announcement {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId      String    @db.ObjectId
  title         String
  content       String
  targetRoles   Role[]
  targetClasses String[]
  isSchoolWide  Boolean   @default(false)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

// ============================================
// AUDIT
// ============================================

model AuditLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId      String   @db.ObjectId
  userId        String   @db.ObjectId
  action        String
  resource      String
  resourceId    String
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  timestamp     DateTime @default(now())

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([resource])
  @@index([timestamp])
}

// ============================================
// AUTHENTICATION AUDIT
// ============================================

enum AuthEventType {
  LOGIN_ATTEMPT
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  ROLE_SWITCH
  PASSWORD_CHANGE
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  SUSPICIOUS_ACTIVITY
  // Impersonation events - Requirement 5.6
  IMPERSONATION_START
  IMPERSONATION_ACTION
  IMPERSONATION_END
}

model AuthAuditLog {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  userId     String?       @db.ObjectId
  schoolId   String?       @db.ObjectId
  eventType  AuthEventType
  identifier String // Email/phone/username used for login
  ipAddress  String
  userAgent  String?
  success    Boolean
  errorCode  String?
  metadata   Json?
  timestamp  DateTime      @default(now())

  // Relations
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  school School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([schoolId])
  @@index([eventType])
  @@index([timestamp])
  @@index([ipAddress])
  @@index([identifier])
}

// ============================================
// RATE LIMITING
// ============================================

model LoginAttempt {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  identifier   String // Email, phone, or IP address
  ipAddress    String
  attempts     Int       @default(1)
  firstAttempt DateTime  @default(now())
  lastAttempt  DateTime  @default(now())
  lockedUntil  DateTime?

  @@unique([identifier, ipAddress])
  @@index([identifier])
  @@index([ipAddress])
  @@index([lockedUntil])
}

// ============================================
// STUDENT DOCUMENTS
// ============================================

model StudentDocument {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId  String   @db.ObjectId
  name       String
  type       String
  url        String
  metadata   Json?
  uploadedAt DateTime @default(now())

  // Relations
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

// ============================================
// URL SHORTENING
// ============================================

model ShortUrl {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  code        String    @unique
  originalUrl String
  schoolId    String?   @db.ObjectId
  studentId   String?   @db.ObjectId
  messageId   String?   @db.ObjectId
  channel     String? // SMS, WHATSAPP, EMAIL - for tracking source
  clickCount  Int       @default(0)
  lastClickAt DateTime?
  expiresAt   DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Click tracking
  clicks ShortUrlClick[]

  @@index([schoolId])
  @@index([studentId])
  @@index([messageId])
  @@index([isActive])
}

model ShortUrlClick {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  shortUrlId String   @db.ObjectId
  ipAddress  String?
  userAgent  String?
  referer    String?
  clickedAt  DateTime @default(now())

  // Relations
  shortUrl ShortUrl @relation(fields: [shortUrlId], references: [id], onDelete: Cascade)

  @@index([shortUrlId])
  @@index([clickedAt])
}

// ============================================
// BULK MESSAGING
// ============================================

enum BulkMessageJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model BulkMessageJob {
  id                  String               @id @default(auto()) @map("_id") @db.ObjectId
  schoolId            String               @db.ObjectId
  totalMessages       Int
  processedCount      Int                  @default(0)
  sentCount           Int                  @default(0)
  failedCount         Int                  @default(0)
  status              BulkMessageJobStatus @default(PENDING)
  errorMessage        String?
  estimatedCompletion DateTime?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  // Relations
  items BulkMessageItem[]

  @@index([schoolId])
  @@index([status])
  @@index([createdAt])
}

model BulkMessageItem {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  jobId        String        @db.ObjectId
  studentId    String        @db.ObjectId
  templateType String
  data         Json
  priority     String        @default("normal")
  status       MessageStatus @default(QUEUED)
  messageId    String?       @db.ObjectId // Reference to created Message
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime      @default(now())

  // Relations
  job BulkMessageJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([studentId])
  @@index([status])
}

// ============================================
// SMS BUDGET TRACKING
// ============================================

enum SMSBudgetAlertType {
  WARNING_80
  EXCEEDED_100
  BUDGET_RESET
}

model SMSBudgetUsage {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String              @db.ObjectId
  termId      String              @db.ObjectId
  totalBudget Float // Budget limit in UGX
