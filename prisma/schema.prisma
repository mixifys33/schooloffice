// PDF Storage - Store generated report card PDFs
model PDFStorage {
  id        String   @id @map("_id") // Custom ID format: schoolId-termId-studentId-timestamp
  studentId String   @db.ObjectId
  termId    String   @db.ObjectId
  schoolId  String   @db.ObjectId
  pdfData   String // Base64 encoded PDF
  fileSize  Int // File size in bytes
  createdAt DateTime @default(now())

  // Relations
  accesses PDFAccess[]

  @@index([studentId])
  @@index([termId])
  @@index([schoolId])
  @@index([createdAt])
  @@map("pdf_storage")
}

// PDF Access - Track who accessed PDFs (analytics)
model PDFAccess {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId     String   @db.ObjectId
  pdfStorageId String // Reference to PDFStorage.id
  accessedAt   DateTime @default(now())
  ipAddress    String?
  userAgent    String?

  // Relations
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pdfStorage PDFStorage @relation(fields: [pdfStorageId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([pdfStorageId])
  @@index([accessedAt])
  @@map("pdf_access")
}

// Published Report - Enhanced with PDF URLs
model PublishedReport {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId    String   @db.ObjectId
  termId       String   @db.ObjectId
  schoolId     String   @db.ObjectId
  publishedBy  String   @db.ObjectId
  publishedAt  DateTime @default(now())
  htmlContent  String // HTML version of report card
  pdfUrl       String? // Full URL to PDF (e.g., https://example.com/api/reports/pdf/xyz)
  shortUrl     String? // Shortened URL (e.g., https://tama.ri/ABC1)
  isAccessible Boolean  @default(true) // Can be toggled to revoke access

  @@unique([studentId, termId])
  @@index([studentId])
  @@index([termId])
  @@index([schoolId])
  @@index([publishedAt])
  @@map("published_reports")
}

// ============================================
// REPORT CARD SYSTEM
// Complete report card generation, approval, and publishing workflow
// ============================================

// Report Card - Main report card record
model ReportCard {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String   @db.ObjectId
  studentId   String   @db.ObjectId
  classId     String   @db.ObjectId
  termId      String   @db.ObjectId
  
  // PDF Storage
  pdfUrl      String?  // URL to stored PDF (Cloudinary/S3)
  pdfSize     Int?     // File size in bytes
  
  // Status tracking
  status      ReportCardStatus @default(DRAFT)
  generatedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?  @db.ObjectId // Staff ID
  publishedAt DateTime?
  publishedBy String?  @db.ObjectId // Staff ID
  
  // Download tracking
  downloadCount Int @default(0)
  lastDownloadAt DateTime?
  
  // Secure link
  secureToken String?  @unique
  linkExpiresAt DateTime?
  
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  term        Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  approver    Staff?   @relation("ReportCardApprover", fields: [approvedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  publisher   Staff?   @relation("ReportCardPublisher", fields: [publishedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@unique([studentId, termId])
  @@index([schoolId, termId, status])
  @@index([classId, termId])
  @@index([status])
  @@map("report_cards")
}

// Template Type Enum
enum TemplateType {
  NEW_CURRICULUM
  LEGACY
  CUSTOM
}

// Report Template - Report card templates
model ReportTemplate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String   @db.ObjectId
  name        String
  type        TemplateType
  
  // Template content (Handlebars HTML)
  content     String?  // Template markup (null for system default)
  variables   Json     // Available variables
  
  // Status
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  isSystemTemplate Boolean @default(false) // Cannot be deleted/edited
  
  // Usage tracking
  usageCount  Int      @default(0)
  lastUsedAt  DateTime?
  
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String   @db.ObjectId
  
  // Relations
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  creator     Staff    @relation("TemplateCreator", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@unique([schoolId, name])
  @@index([schoolId, type, isDefault])
  @@index([isActive])
  @@map("report_templates")
}

// Report Action Enum
enum ReportAction {
  GENERATED
  APPROVED
  PUBLISHED
  REGENERATED
  REVOKED
  DOWNLOADED
}

// Report Generation Log - Audit trail for report operations
model ReportGenerationLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String   @db.ObjectId
  classId     String   @db.ObjectId
  termId      String   @db.ObjectId
  
  // Generation details
  action      ReportAction
  status      String   // SUCCESS, FAILED, PARTIAL
  
  // Stats
  totalStudents    Int
  successCount     Int
  failureCount     Int
  generationTime   Float  // seconds
  
  // Error tracking
  errors      Json?    // Array of errors
  
  // Metadata
  performedBy String   @db.ObjectId
  performedAt DateTime @default(now())
  
  // Relations
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  term        Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  staff       Staff    @relation("ReportLogStaff", fields: [performedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@index([schoolId, termId])
  @@index([classId, termId])
  @@index([action])
  @@index([performedAt])
  @@map("report_generation_logs")
}

