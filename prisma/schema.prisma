// ============================================
// TIMETABLE SYSTEM MODELS - COMPREHENSIVE ARCHITECTURE
// ============================================

// School Time Structure - Foundation of all timetables
model SchoolTimeStructure {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String @db.ObjectId

  // Time configuration
  startTime      String // "08:00"
  endTime        String // "15:30"
  periodsPerDay  Int // 8
  periodDuration Int // 40 minutes

  // Break configuration
  shortBreakStart    Int // Period after which short break occurs (e.g., 3)
  shortBreakDuration Int // 20 minutes
  lunchBreakStart    Int // Period after which lunch occurs (e.g., 5)
  lunchBreakDuration Int // 60 minutes

  // Status
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, isActive])
  @@index([schoolId])
  @@index([isActive])
  @@map("school_time_structures")
}

// Subject Period Requirements - New curriculum compliance
model SubjectPeriodRequirement {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String @db.ObjectId
  subjectId String @db.ObjectId
  classId   String @db.ObjectId

  // Period requirements
  periodsPerWeek      Int // Required periods per week
  doublePeriodAllowed Boolean @default(false)
  practicalPeriods    Int     @default(0) // Lab/practical periods
  theoryPeriods       Int     @default(0) // Calculated: periodsPerWeek - practicalPeriods

  // New curriculum specific
  isCompetencyBased     Boolean @default(false)
  requiresProjectBlocks Boolean @default(false)
  cannotBeSplit         Boolean @default(false) // Some subjects need consecutive periods

  // Preferences
  preferMorningSlots   Boolean @default(false)
  preferAfternoonSlots Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([schoolId, subjectId, classId])
  @@index([schoolId])
  @@index([subjectId])
  @@index([classId])
  @@map("subject_period_requirements")
