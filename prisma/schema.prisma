// ============================================
// ENHANCED BURSAR MODULE - BUDGET & EXPENSE TRACKING
// ============================================

// Budget Categories for school-wide financial planning
model BudgetCategory {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  schoolId        String       @db.ObjectId
  name            String
  description     String?
  budgetedAmount  Float
  spentAmount     Float        @default(0)
  remainingAmount Float
  percentage      Float        @default(0) // Percentage of budget used
  status          BudgetStatus @default(ON_TRACK)
  department      String?
  period          BudgetPeriod @default(TERMLY)
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean      @default(true)
  createdBy       String       @db.ObjectId
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  expenses     Expense[]
  budgetAlerts BudgetAlert[]

  @@index([schoolId])
  @@index([status])
  @@index([period])
  @@index([isActive])
}

// Budget Status Enum
enum BudgetStatus {
  ON_TRACK
  AT_RISK
  OVER_BUDGET
  COMPLETED
}

// Budget Period Enum
enum BudgetPeriod {
  MONTHLY
  TERMLY
  ANNUALLY
}

// Expense records for tracking actual spending
model Expense {
  id               String        @id @default(auto()) @map("_id") @db.ObjectId
  schoolId         String        @db.ObjectId
  budgetCategoryId String        @db.ObjectId
  description      String
  amount           Float
  expenseDate      DateTime
  vendor           String?
  receiptNumber    String?
  receiptUrl       String? // ImageKit URL for receipt
  paymentMethod    PaymentMethod
  status           ExpenseStatus @default(PENDING)
  approvedBy       String?       @db.ObjectId
  approvedAt       DateTime?
  rejectedBy       String?       @db.ObjectId
  rejectedAt       DateTime?
  rejectionReason  String?
  notes            String?
  createdBy        String        @db.ObjectId
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  budgetCategory BudgetCategory @relation(fields: [budgetCategoryId], references: [id])

  @@index([schoolId])
  @@index([budgetCategoryId])
  @@index([status])
  @@index([expenseDate])
}

// Expense Status Enum
enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// Budget Alerts for monitoring spending
model BudgetAlert {
  id               String          @id @default(auto()) @map("_id") @db.ObjectId
  schoolId         String          @db.ObjectId
  budgetCategoryId String          @db.ObjectId
  alertType        BudgetAlertType
  threshold        Float // Percentage threshold that triggered alert
  currentSpending  Float
  budgetAmount     Float
  message          String
  isActive         Boolean         @default(true)
  acknowledgedBy   String?         @db.ObjectId
  acknowledgedAt   DateTime?
  createdAt        DateTime        @default(now())

  // Relations
  budgetCategory BudgetCategory @relation(fields: [budgetCategoryId], references: [id])

  @@index([schoolId])
  @@index([budgetCategoryId])
  @@index([alertType])
  @@index([isActive])
}

// Budget Alert Types
enum BudgetAlertType {
  WARNING_75 // 75% of budget used
  CRITICAL_90 // 90% of budget used
  EXCEEDED_100 // Budget exceeded
  MONTHLY_LIMIT // Monthly spending limit exceeded
}

// Cash Flow Projections
model CashFlowProjection {
