  CREATED
  UPDATED
  STATUS_CHANGED
  ACCESS_GRANTED
  ACCESS_REVOKED
  PERMISSIONS_UPDATED
  SUBJECT_ASSIGNED
  SUBJECT_REMOVED
  CLASS_ASSIGNED
  CLASS_REMOVED
  CLASS_TEACHER_DESIGNATED
  EXAM_ROLE_ASSIGNED
  DOCUMENT_UPLOADED
  PAYROLL_UPDATED
}

// Teacher Model - Requirements 1.1-1.6, 2.1-2.9, 3.1-3.9, 4.1-4.8
model Teacher {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String @db.ObjectId

  // Personal Information - Requirement 1.1
  firstName   String
  lastName    String
  gender      Gender
  nationalId  String // National ID/Passport/Staff ID - unique per school
  phone       String
  email       String // Unique per school
  dateOfBirth DateTime
  photo       String?
  address     String?

  // Employment Details - Requirements 2.1-2.5
  employmentType    TeacherEmploymentType
  jobTitle          TeacherJobTitle
  department        String
  dateOfAppointment DateTime
  employmentStatus  TeacherEmploymentStatus @default(ACTIVE)

  // System Access - Requirements 4.1-4.8
  userId             String?            @db.ObjectId // Linked user account (if access granted)
  hasSystemAccess    Boolean            @default(false)
  accessLevel        TeacherAccessLevel @default(NONE)
  canTakeAttendance  Boolean            @default(true)
  canEnterMarks      Boolean            @default(true)
  canViewReports     Boolean            @default(true)
  canSendMessages    Boolean            @default(false)
  forcePasswordReset Boolean            @default(true)

  // Communication Channels - Requirements 5.1-5.2
  inAppMessagingEnabled Boolean @default(true)
  smsEnabled            Boolean @default(false) // Disabled by default per Requirement 5.2
  whatsappEnabled       Boolean @default(false) // Disabled by default per Requirement 5.2
  emailEnabled          Boolean @default(true)

  // Academic Assignments - Requirements 3.1-3.5
  assignedSubjectIds String[] @db.ObjectId // Subject IDs
  assignedClassIds   String[] @db.ObjectId // Class IDs
  assignedStreamIds  String[] @db.ObjectId // Stream IDs
  classTeacherForIds String[] @db.ObjectId // Class IDs where designated as class teacher

  // Payroll Preparation - Requirements 8.1-8.5
  salaryType          TeacherSalaryType?
  payGrade            String?
  paymentStatus       TeacherPaymentStatus?
  bankName            String?
  bankAccountNumber   String?
  bankAccountName     String?
  mobileMoneyProvider String?
  mobileMoneyPhone    String?
  mobileMoneyName     String?

  // Metadata
  createdBy String   @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school             School                             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  documents          TeacherDocument[]
  historyEntries     TeacherHistoryEntry[]
  examinationRoles   TeacherExaminationRoleAssignment[]
  performanceMetrics TeacherPerformanceMetric[]
  assignments        Assignment[]

  @@unique([schoolId, email])
  @@unique([schoolId, nationalId])
  @@index([schoolId])
  @@index([employmentStatus])
  @@index([department])
  @@index([employmentType])
  @@index([hasSystemAccess])
}

// Teacher Document Model - Requirements 7.1-7.7
model TeacherDocument {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  teacherId    String              @db.ObjectId
  documentType TeacherDocumentType
  fileName     String
  fileUrl      String // ImageKit URL - Requirement 7.5
  fileSize     Int
  mimeType     String
  uploadedBy   String              @db.ObjectId
  uploadedAt   DateTime            @default(now())

  // Relations
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([documentType])
}

// Teacher History Entry Model - Requirement 2.9, 3.9
model TeacherHistoryEntry {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  teacherId     String           @db.ObjectId
  eventType     TeacherEventType
  previousValue String?
  newValue      String?
  reason        String?
  performedBy   String           @db.ObjectId
  performedAt   DateTime         @default(now())
  createdAt     DateTime         @default(now())

  // Relations
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([eventType])
  @@index([performedAt])
}

// Teacher Examination Role Assignment - Requirement 3.5
model TeacherExaminationRoleAssignment {
  id         String                 @id @default(auto()) @map("_id") @db.ObjectId
  teacherId  String                 @db.ObjectId
  examId     String                 @db.ObjectId
  role       TeacherExaminationRole
  assignedAt DateTime               @default(now())
  assignedBy String                 @db.ObjectId

  // Relations
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, examId, role])
  @@index([teacherId])
  @@index([examId])
}

// Teacher Draft Model - Requirement 9.2
model TeacherDraft {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String   @db.ObjectId
  data        Json // Partial<CreateTeacherInput>
  currentStep Int      @default(1) // 1-5 for the form steps
  createdBy   String   @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([createdBy])
}

// Teacher Performance Metric - Requirements 6.1-6.7
model TeacherPerformanceMetric {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  teacherId   String   @db.ObjectId
  schoolId    String   @db.ObjectId
  periodStart DateTime
  periodEnd   DateTime

  // Attendance Submission Tracking - Requirement 6.1
  attendanceExpected  Int @default(0)
  attendanceSubmitted Int @default(0)
  attendanceOnTime    Int @default(0)
  attendanceLate      Int @default(0)

  // Mark Entry Tracking - Requirement 6.2
  marksExpected Int @default(0)
  marksEntered  Int @default(0)
  marksOnTime   Int @default(0)
  marksLate     Int @default(0)

  // Missed Classes Tracking - Requirement 6.3
  missedClassCount Int @default(0)

  // Login Activity - Requirement 6.4
  loginCount          Int       @default(0)
  lastLoginAt         DateTime?
  totalSessionMinutes Int       @default(0)

  // Message Logs - Requirement 6.5
  messagesSent       Int       @default(0)
  messagesBySms      Int       @default(0)
  messagesByWhatsapp Int       @default(0)
  messagesByEmail    Int       @default(0)
  messagesByInApp    Int       @default(0)
  lastMessageAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, periodStart, periodEnd])
  @@index([teacherId])
  @@index([schoolId])
  @@index([periodStart])
  @@index([periodEnd])
}

// ============================================
// SCHOOL ASSETS - ImageKit Integration
// ============================================

// School Asset Types
enum SchoolAssetType {
  LOGO
  LETTERHEAD
  CERTIFICATE_TEMPLATE
  REPORT_TEMPLATE
  GENERAL
}

// School Asset Model - stores school documents and templates
model SchoolAsset {
  id         String          @id @default(auto()) @map("_id") @db.ObjectId
  schoolId   String          @db.ObjectId
  assetType  SchoolAssetType
  name       String
  fileName   String
  fileUrl    String // ImageKit URL
  fileSize   Int             @default(0)
  mimeType   String
  fileId     String? // ImageKit file ID for deletion
  uploadedBy String          @db.ObjectId
  uploadedAt DateTime        @default(now())
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([schoolId])
  @@index([assetType])
  @@index([uploadedAt])
}

// ============================================
// STAFF ATTENDANCE TRACKING
// Requirements: Staff performance metrics
// ============================================

enum StaffAttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

model StaffAttendance {
  id         String                @id @default(auto()) @map("_id") @db.ObjectId
  staffId    String                @db.ObjectId
  schoolId   String                @db.ObjectId
  date       DateTime
  status     StaffAttendanceStatus
  checkInAt  DateTime?
  checkOutAt DateTime?
  lateMinutes Int                  @default(0)
  remarks    String?
  recordedBy String                @db.ObjectId
  recordedAt DateTime              @default(now())
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  @@unique([staffId, date])
  @@index([staffId])
  @@index([schoolId])
  @@index([date])
  @@index([status])
}

// ============================================
// TEACHER ASSIGNMENTS (Homework/Tasks)
// Requirements: 7.1-7.5 - Assignment Management Module
// ============================================

enum AssignmentStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

enum SubmissionStatus {
  NOT_SUBMITTED
  SUBMITTED
  LATE
  GRADED
}

// Assignment Model - Teacher-created homework/tasks
model Assignment {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String           @db.ObjectId
  teacherId   String           @db.ObjectId
  classId     String           @db.ObjectId
  subjectId   String           @db.ObjectId
  title       String
  description String
  deadline    DateTime
  attachments String[]         // File URLs
  status      AssignmentStatus @default(PUBLISHED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  teacher     Teacher                @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@index([schoolId])
  @@index([teacherId])
  @@index([classId])
  @@index([subjectId])
  @@index([deadline])
  @@index([status])
}

// Assignment Submission - Student submission tracking
model AssignmentSubmission {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId String           @db.ObjectId
  studentId    String           @db.ObjectId
  status       SubmissionStatus @default(NOT_SUBMITTED)
  submittedAt  DateTime?
  attachments  String[]         // File URLs
  grade        String?
  feedback     String?
  gradedAt     DateTime?
  gradedBy     String?          @db.ObjectId
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  // Relations
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
}
