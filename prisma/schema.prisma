// FINANCE
// ============================================

// Fee Category Types
enum FeeCategory {
  TUITION
  BOARDING
  TRANSPORT
  MEALS
  UNIFORM
  BOOKS
  EXAMINATION
  ACTIVITY
  OTHER
}

// Student Type for fee differentiation
enum StudentType {
  DAY
  BOARDING
}

// Discount Types
enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// Discount Approval Status
enum DiscountStatus {
  PENDING
  APPROVED
  REJECTED
}

// Invoice Status
enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

// Payment Status for tracking
enum PaymentRecordStatus {
  PENDING
  CONFIRMED
  REVERSED
  CANCELLED
}

enum StudentAccountStatus {
  OK
  WARNING
  CRITICAL
}

enum TrackerStatus {
  PENDING
  CLEARED
}

enum AutomationFrequency {
  WEEKLY
  BIWEEKLY
  TRI_WEEKLY
}

model FeeStructure {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String      @db.ObjectId
  classId     String      @db.ObjectId
  termId      String      @db.ObjectId
  studentType StudentType @default(DAY)
  totalAmount Float
  dueDate     DateTime?
  isActive    Boolean     @default(true)
  createdBy   String      @db.ObjectId
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Milestones for automation (PART 2.1)
  milestones Json? // Array of { week: number, percentage: number }
  lockedAt   DateTime? // When term starts/rules are frozen

  // Relations
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class    Class     @relation(fields: [classId], references: [id])
  term     Term      @relation(fields: [termId], references: [id])
  items    FeeItem[]
  invoices Invoice[]

  @@unique([schoolId, classId, termId, studentType])
  @@index([schoolId])
  @@index([classId])
  @@index([termId])
  @@index([isActive])
}

model FeeItem {
  id             String      @id @default(auto()) @map("_id") @db.ObjectId
  schoolId       String      @db.ObjectId
  feeStructureId String      @db.ObjectId
  name           String
  category       FeeCategory @default(OTHER)
  amount         Float
  isOptional     Boolean     @default(false)
  isOneTime      Boolean     @default(false)
  description    String?
  createdAt      DateTime    @default(now())

  // Relations
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure @relation(fields: [feeStructureId], references: [id], onDelete: Cascade)

  @@index([feeStructureId])
  @@index([category])
  @@index([schoolId])
}

// Student Account - tracks individual student financial status per term
model StudentAccount {
  id                String               @id @default(auto()) @map("_id") @db.ObjectId
  studentId         String               @db.ObjectId
  schoolId          String               @db.ObjectId
  termId            String               @db.ObjectId
  studentType       StudentType          @default(DAY)
  totalFees         Float                @default(0)
  totalPaid         Float                @default(0)
  totalDiscounts    Float                @default(0)
  totalPenalties    Float                @default(0)
  balance           Float                @default(0) // totalFees - totalPaid - totalDiscounts + totalPenalties
  status            StudentAccountStatus @default(OK)
  isExempted        Boolean              @default(false)
  exemptionReason   String?
  lastPaymentDate   DateTime?
  lastPaymentAmount Float?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  // Relations
  student           Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  school            School                   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term              Term                     @relation(fields: [termId], references: [id], onDelete: Cascade)
  discounts         StudentDiscount[]
  penalties         StudentPenalty[]
  milestoneStatuses StudentMilestoneStatus[]

  // CORRECTED: Now scoped per student, per term, per school
  @@unique([studentId, termId]) // Non-negotiable: (studentId, termId) identity
  @@index([schoolId])
  @@index([termId])
  @@index([balance])
}

// Discount definitions (school-wide discount rules)
