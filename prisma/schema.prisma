enum RoomType {
  CLASSROOM
  LABORATORY
  COMPUTER_LAB
  LIBRARY
  HALL
  SPORTS_FACILITY
}

// Timetable Status Enum
enum TimetableStatus {
  DRAFT
  REVIEWED
  APPROVED
  PUBLISHED
  ARCHIVED
}

// Generation Status Enum
enum GenerationStatus {
  IDLE
  RUNNING
  COMPLETED
  FAILED
}

// Conflict Severity Enum
enum ConflictSeverity {
  INFO
  WARNING
  CRITICAL
}

// Constraint Type Enum
enum ConstraintType {
  TEACHER_CLASH
  ROOM_CLASH
  CLASS_CLASH
  SUBJECT_PERIODS
  TEACHER_OVERLOAD
  CONSTRAINT_VIOLATION
}

// Timetable Draft - Versioned timetables with approval workflow
model TimetableDraft {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String @db.ObjectId
  termId   String @db.ObjectId

  // Basic info
  name String // "Term 1 2024 - Draft 1"

  // Version control
  version Int             @default(1)
  status  TimetableStatus @default(DRAFT)

  // Generation metadata
  generatedBy         String           @db.ObjectId // User ID
  generatedAt         DateTime         @default(now())
  generationAlgorithm String? // Algorithm used (e.g., "Genetic Algorithm")
  generationTime      Int? // Milliseconds taken
  generationStatus    GenerationStatus @default(IDLE)
  generationStarted   DateTime?
  generationEnded     DateTime?
  generationLog       Json? // Detailed generation logs

  // Quality metrics
  qualityScore             Float? // 0-100 quality score
  totalSlots               Int    @default(0)
  filledSlots              Int    @default(0)
  conflictCount            Int    @default(0)
  hardConstraintViolations Int    @default(0)
  softConstraintViolations Int    @default(0)

  // Approval workflow
  reviewedBy  String?   @db.ObjectId // User ID
  reviewedAt  DateTime?
  reviewNotes String?

  approvedBy    String?   @db.ObjectId // User ID (DoS)
  approvedAt    DateTime?
  approvalNotes String?

  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school    School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term      Term                @relation(fields: [termId], references: [id], onDelete: Cascade)
  slots     TimetableSlot[]
  conflicts TimetableConflict[]
  approval  TimetableApproval?

  @@unique([schoolId, termId, version])
  @@index([schoolId])
  @@index([termId])
  @@index([status])
  @@index([generationStatus])
  @@index([generatedAt])
  @@map("timetable_drafts")
}

// Timetable Slot - Individual time slots in a timetable
model TimetableSlot {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  schoolId     String  @db.ObjectId
  timetableId  String  @db.ObjectId
  classId      String  @db.ObjectId
  subjectId    String  @db.ObjectId
  teacherId    String  @db.ObjectId
  dayOfWeek    Int // 1-7 (Monday-Sunday)
  period       Int // Period number
  roomId       String? @db.ObjectId // Room identifier
  roomName     String? // Room name for display
  duration     Int     @default(40) // Duration in minutes
  isDoubleSlot Boolean @default(false)
  notes        String?

  // Conflict tracking
  hasConflict  Boolean @default(false)
  conflictType String? // TEACHER_CLASH, ROOM_CLASH, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school    School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timetable TimetableDraft @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  class     Class          @relation(fields: [classId], references: [id])
  subject   Subject        @relation(fields: [subjectId], references: [id])
  teacher   Staff          @relation(fields: [teacherId], references: [id])
  room      Room?          @relation(fields: [roomId], references: [id])

  @@unique([timetableId, dayOfWeek, period, classId])
  @@index([schoolId])
  @@index([timetableId])
  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([dayOfWeek])
  @@index([period])
  @@index([hasConflict])
  @@map("timetable_slots")
}

// Timetable Conflict - Conflicts detected in timetables
model TimetableConflict {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  schoolId      String           @db.ObjectId
  timetableId   String           @db.ObjectId
  conflictType  ConstraintType // TEACHER_CLASH, ROOM_CLASH, CLASS_CLASH, etc.
  severity      ConflictSeverity // INFO, WARNING, CRITICAL
  title         String
  description   String
  affectedSlots Json // Array of slot IDs involved in conflict
  suggestedFix  Json? // Suggested resolution
  isResolved    Boolean          @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?          @db.ObjectId
  dismissedAt   DateTime?
  dismissedBy   String?          @db.ObjectId
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  school    School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timetable TimetableDraft @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([timetableId])
  @@index([conflictType])
  @@index([severity])
  @@index([isResolved])
  @@index([createdAt])
  @@map("timetable_conflicts")
}

// Timetable Approval - Tracks approval workflow for timetables
model TimetableApproval {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String @db.ObjectId
  draftId  String @unique @db.ObjectId

  // Submission
  submittedBy String   @db.ObjectId // DoS user ID
  submittedAt DateTime @default(now())

  // Review
  reviewedBy   String?   @db.ObjectId // DoS user ID
  reviewedAt   DateTime?
  reviewStatus String? // APPROVE, REJECT, REQUEST_CHANGES
  reviewNotes  String?

  // Publication
  publishedBy      String?   @db.ObjectId // DoS user ID
  publishedAt      DateTime?
  teachersNotified Boolean   @default(false)
  studentsNotified Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  draft TimetableDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([submittedAt])
  @@index([publishedAt])
  @@map("timetable_approvals")
}

// Enhanced Announcement - Requirements 6.1, 6.2, 6.3, 6.4, 6.5
