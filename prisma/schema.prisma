  school               School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  continuousAssessment ContinuousAssessment @relation(fields: [continuousAssessmentId], references: [id])
  student              Student              @relation(fields: [studentId], references: [id])
  enteredByStaff       Staff                @relation(fields: [enteredBy], references: [id])

  @@unique([continuousAssessmentId, studentId])
  @@index([schoolId])
  @@index([continuousAssessmentId])
  @@index([studentId])
  @@index([enteredBy])
}

// ============================================
// CLASS TEACHER MARKS MANAGEMENT SYSTEM
// New Curriculum CA and Exam Entry Models
// ============================================

// CA Entry Types for new curriculum
enum CAType {
  ASSIGNMENT
  TEST
  PROJECT
  PRACTICAL
  OBSERVATION
}

// Marks Submission Status for new curriculum workflow
enum MarksSubmissionStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

// CA Entry Model - Multiple CA entries per subject per term
model CAEntry {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String @db.ObjectId

  // Relations
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id])
  studentId String  @db.ObjectId
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId String  @db.ObjectId
  teacher   Staff   @relation(fields: [teacherId], references: [id])
  teacherId String  @db.ObjectId
  term      Term    @relation(fields: [termId], references: [id])
  termId    String  @db.ObjectId

  // CA Entry Details
  name     String // e.g., "Assignment 1 - Algebra"
  type     CAType
  maxScore Float
  rawScore Float
  date     DateTime

  // Curriculum Integration
  competencyId      String?
  competencyComment String?

  // Workflow
  status      MarksSubmissionStatus @default(DRAFT)
  submittedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Competency Relations
  competencyMappings CompetencyMapping[]

  @@unique([studentId, name, type, termId, subjectId])
  @@index([studentId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([termId])
  @@index([type])
  @@index([status])
  @@index([schoolId])
  @@map("ca_entries")
}

// Exam Entry Model - One exam per student per subject per term
model ExamEntry {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String @db.ObjectId

  // Relations
  school    School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id])
  studentId String  @db.ObjectId
  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId String  @db.ObjectId
  teacher   Staff   @relation(fields: [teacherId], references: [id])
  teacherId String  @db.ObjectId
  term      Term    @relation(fields: [termId], references: [id])
  termId    String  @db.ObjectId

  // Exam Details
  examScore Float // Out of 100
  maxScore  Float    @default(100) // Always 100
  examDate  DateTime

  // Workflow
  status      MarksSubmissionStatus @default(DRAFT)
  submittedAt DateTime?
  approvedAt  DateTime?
  approvedBy  String?

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ensure one exam per student per subject per term
  @@unique([studentId, subjectId, termId])
  @@index([studentId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([termId])
  @@index([status])
  @@index([schoolId])
  @@map("exam_entries")
}

// ============================================
// COMPETENCY-BASED ASSESSMENT MODELS
// Requirements: 31.1, 31.2, 31.3, 31.4, 31.5, 31.6, 31.7
// ============================================

enum CompetencyLevel {
  EMERGING
  DEVELOPING
  PROFICIENT
  ADVANCED
}

enum CompetencyType {
  KNOWLEDGE
  SKILLS
  VALUES_ATTITUDES
  GENERIC_SKILLS
}

// Competency Definition Model
model Competency {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String          @db.ObjectId
  subjectId   String          @db.ObjectId
  classId     String          @db.ObjectId
  code        String // e.g., "M1.1", "E2.3"
  title       String
  description String
  type        CompetencyType
  level       CompetencyLevel @default(DEVELOPING)

  // Hierarchical structure
  parentCompetencyId String?      @db.ObjectId
  parentCompetency   Competency?  @relation("CompetencyHierarchy", fields: [parentCompetencyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subCompetencies    Competency[] @relation("CompetencyHierarchy")

  // Metadata
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String   @db.ObjectId

  // Relations
  school          School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject         Subject                @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class           Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  progressRecords CompetencyProgress[]
  mappings        CompetencyMapping[]
  auditTrail      CompetencyAuditTrail[]

  @@unique([schoolId, subjectId, classId, code])
  @@index([schoolId])
  @@index([subjectId])
  @@index([classId])
  @@index([type])
  @@index([level])
  @@index([isActive])
  @@map("competencies")
}

// Student Competency Progress Tracking
model CompetencyProgress {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  schoolId          String          @db.ObjectId
  studentId         String          @db.ObjectId
  competencyId      String          @db.ObjectId
  termId            String          @db.ObjectId
  currentLevel      CompetencyLevel @default(EMERGING)
  evidenceCount     Int             @default(0)
  averageScore      Float           @default(0)
  masteryPercentage Float           @default(0)
  lastAssessedAt    DateTime?
  teacherComment    String?

  // Metadata
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastUpdatedBy String   @db.ObjectId

  // Relations
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  competency Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  term       Term       @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, competencyId, termId])
  @@index([schoolId])
  @@index([studentId])
  @@index([competencyId])
  @@index([termId])
  @@index([currentLevel])
  @@index([masteryPercentage])
  @@map("competency_progress")
}

// CA Entry to Competency Mapping
model CompetencyMapping {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  schoolId       String  @db.ObjectId
  caEntryId      String  @db.ObjectId
  competencyId   String  @db.ObjectId
  evidenceType   String // Type of evidence this CA provides
  weight         Float   @default(1.0) // How much this CA contributes to competency mastery
  teacherComment String?

  // Metadata
  createdAt DateTime @default(now())
  createdBy String   @db.ObjectId

  // Relations
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  caEntry    CAEntry    @relation(fields: [caEntryId], references: [id], onDelete: Cascade)
  competency Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)

  @@unique([caEntryId, competencyId])
  @@index([schoolId])
  @@index([caEntryId])
  @@index([competencyId])
  @@index([evidenceType])
  @@map("competency_mappings")
}

// Competency Audit Trail
model CompetencyAuditTrail {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId      String   @db.ObjectId
  competencyId  String   @db.ObjectId
  studentId     String?  @db.ObjectId
  action        String // LINKED, UNLINKED, LEVEL_CHANGED, COMMENT_ADDED, PROGRESS_UPDATED
  previousValue Json?
  newValue      Json?
  performedBy   String   @db.ObjectId
  performedAt   DateTime @default(now())
  reason        String?

  // Relations
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  competency Competency @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  student    Student?   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([competencyId])
  @@index([studentId])
  @@index([action])
  @@index([performedAt])
  @@map("competency_audit_trail")
}

// ============================================
// END OF SCHEMA
// ============================================

// Timetable Version History - Complete audit trail
model TimetableVersion {
  id       String          @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String          @db.ObjectId
  termId   String          @db.ObjectId
  version  Int
  status   TimetableStatus

  // Change tracking
  changedBy      String  @db.ObjectId // User who made changes
  changeReason   String? // Reason for creating new version
  changesFrom    String? @db.ObjectId // Previous version ID
  changesSummary Json? // Summary of what changed

  // Metadata
  totalSlots    Int    @default(0)
  conflictCount Int    @default(0)
  qualityScore  Float? // 0-100 quality score

  // Timestamps
  createdAt  DateTime  @default(now())
  archivedAt DateTime?

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, termId, version])
  @@index([schoolId])
  @@index([termId])
  @@index([status])
  @@index([createdAt])
  @@map("timetable_versions")
}

// Timetable Conflict Log - Comprehensive conflict tracking
model TimetableConflictLog {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String  @db.ObjectId
  timetableId String? @db.ObjectId // Null for system-wide conflicts

  // Conflict details
  conflictType String // TEACHER_CLASH, ROOM_CLASH, CLASS_CLASH, MISSING_PERIODS, TEACHER_OVERLOAD, CONSTRAINT_VIOLATION
  severity     String // INFO, WARNING, CRITICAL
  title        String
  description  String

  // Affected entities
  affectedTeachers Json @default("[]") // Teacher IDs
  affectedClasses  Json @default("[]") // Class IDs
  affectedSubjects Json @default("[]") // Subject IDs
  affectedRooms    Json @default("[]") // Room IDs
  affectedSlots    Json @default("[]") // Slot details

  // Resolution
  suggestedFixes   Json      @default("[]") // Array of suggested solutions
  isResolved       Boolean   @default(false)
  resolvedAt       DateTime?
  resolvedBy       String?   @db.ObjectId
  resolutionMethod String? // How it was resolved

  // Dismissal (for non-critical conflicts)
  isDismissed     Boolean   @default(false)
  dismissedAt     DateTime?
  dismissedBy     String?   @db.ObjectId
  dismissalReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([timetableId])
  @@index([conflictType])
  @@index([severity])
  @@index([isResolved])
  @@index([isDismissed])
  @@index([createdAt])
  @@map("timetable_conflict_logs")
}

// Timetable Analytics - DoS insights and performance tracking
model TimetableAnalytics {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String @db.ObjectId
  termId      String @db.ObjectId
  timetableId String @db.ObjectId

  // Teacher workload analytics
  teacherWorkloadStats Json // {teacherId: {periodsPerWeek, maxPeriodsPerDay, utilization}}
  subjectDistribution  Json // {subjectId: {totalPeriods, classCount, teacherCount}}
  roomUtilization      Json // {roomId: {utilizationPercent, peakHours}}

  // Quality metrics
  qualityScore         Float // Overall timetable quality (0-100)
  constraintViolations Int   @default(0)
  softConstraintScore  Float // How well soft constraints are met

  // Balance metrics
  teacherLoadBalance Float // Standard deviation of teacher workloads
  subjectSpreadScore Float // How evenly subjects are distributed

  // Time distribution
  morningSlotUsage   Float // Percentage of morning slots used
  afternoonSlotUsage Float // Percentage of afternoon slots used

  totalSlots Int @default(0) // Added for consistency with usage

  calculatedAt DateTime @default(now())

  @@unique([schoolId, termId, timetableId])
  @@index([schoolId])
  @@index([termId])
  @@index([qualityScore])
  @@index([calculatedAt])
  @@map("timetable_analytics")
}

// Timetable Generation Settings - DoS configuration for generation algorithm
model TimetableGenerationSettings {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String @unique @db.ObjectId

  // Algorithm preferences
  prioritizeTeacherBalance   Boolean @default(true)
  prioritizeSubjectSpread    Boolean @default(true)
  prioritizeRoomOptimization Boolean @default(false)

  // Constraint weights (0-100)
  hardConstraintWeight  Int @default(100) // Never violate
  teacherWorkloadWeight Int @default(80)
  subjectSpreadWeight   Int @default(70)
  roomPreferenceWeight  Int @default(60)
  timePreferenceWeight  Int @default(50)

  // Generation limits
  maxGenerationAttempts Int @default(1000)
  maxGenerationTimeMs   Int @default(30000) // 30 seconds

  // Quality thresholds
  minAcceptableQuality Float @default(70.0)
  targetQualityScore   Float @default(85.0)

  updatedAt DateTime @updatedAt
  updatedBy String   @db.ObjectId

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("timetable_generation_settings")
}

// Timetable Publication Log - Track when timetables are published/unpublished
model TimetablePublicationLog {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String @db.ObjectId
  timetableId String @db.ObjectId

  action      String // PUBLISHED, UNPUBLISHED, REPUBLISHED
  performedBy String  @db.ObjectId // DoS user ID
  reason      String? // Reason for action

  // Notification tracking
  notificationsSent Boolean @default(false)
  notificationCount Int     @default(0)

  performedAt DateTime @default(now())

  @@index([schoolId])
  @@index([timetableId])
  @@index([action])
  @@index([performedAt])
  @@map("timetable_publication_logs")
}

// Marks Audit Log - Complete audit trail for marks approval workflow
model MarksAuditLog {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String @db.ObjectId

  // Entry details
  entryType String // 'CA' or 'EXAM'
  entryId   String @db.ObjectId
  studentId String @db.ObjectId
  subjectId String @db.ObjectId
  classId   String @db.ObjectId
