// Payment Tier for SMS Credit Allocation
enum PaymentTier {
  FULL // 100% payment → 9x student count
  HALF // 50% payment → 4.5x student count, 1 month access
  QUARTER // 25% payment → 2.25x student count, 1 month access
  NONE // No payment → 0 credits, no access
}

// Trigger Event Types for Auto Triggers
enum TriggerEventType {
  FEES_OVERDUE
  PAYMENT_RECEIVED
  REPORT_PUBLISHED
  ATTENDANCE_ABSENT
  EXAM_SCHEDULED
}

// SMS Credit Allocation (Super Admin visibility only)
// Requirements: 2.1, 2.2, 2.3, 2.6, 2.7
model SMSCreditAllocation {
  id               String      @id @default(auto()) @map("_id") @db.ObjectId
  schoolId         String      @unique @db.ObjectId
  paymentTier      PaymentTier
  studentCount     Int
  creditsAllocated Int
  creditsUsed      Int         @default(0)
  creditsRemaining Int
  accessExpiresAt  DateTime? // For HALF and QUARTER tiers
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([paymentTier])
}

// School Subscription Status
// Requirements: 2.4, 2.5
model SchoolSubscription {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  schoolId        String      @unique @db.ObjectId
  paymentTier     PaymentTier
  paymentAmount   Float
  studentCount    Int
  isActive        Boolean     @default(true)
  accessExpiresAt DateTime? // For HALF and QUARTER tiers
  lastPaymentDate DateTime
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([isActive])
  @@index([accessExpiresAt])
}

// Auto Trigger Configuration
// Requirements: 3.1, 3.2, 3.3, 3.4, 3.5
model AutoTrigger {
  id             String           @id @default(auto()) @map("_id") @db.ObjectId
  schoolId       String           @db.ObjectId
  name           String
  eventType      TriggerEventType
  conditions     Json // Array of TriggerCondition
  templateId     String           @db.ObjectId
  enabled        Boolean          @default(true)
  maxPerTerm     Int? // Maximum reminders per term
  intervalDays   Int? // Days between reminders
  lastExecutedAt DateTime?
  executionCount Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([schoolId])
  @@index([eventType])
  @@index([enabled])
}

// Trigger Execution Log
// Requirements: 3.6
model TriggerExecutionLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  triggerId  String   @db.ObjectId
  schoolId   String   @db.ObjectId
  studentId  String   @db.ObjectId
  eventData  Json
  messageId  String?  @db.ObjectId // Reference to created Message
  success    Boolean
  error      String?
  executedAt DateTime @default(now())

  @@index([triggerId])
  @@index([schoolId])
  @@index([studentId])
  @@index([executedAt])
}

// ============================================
// DoS (DIRECTOR OF STUDIES) MODULE - COMPLETE CURRICULUM ARCHITECTURE
// Requirements: Academic Integrity, Curriculum Compliance, Fair Reporting
// ============================================

// DoS Assessment Types - Continuous Assessment (20%)
enum DoSAssessmentType {
  TEST
  ASSIGNMENT
  PROJECT
  PRACTICAL
  QUIZ
  PRESENTATION
}

// DoS Exam Types - End-of-Term/Year Exams (80%)
enum DoSExamType {
  MID_TERM
  END_TERM
  END_YEAR
  MOCK
  PLACEMENT
}

// DoS Grade Descriptors - Academic Performance Levels
enum DoSGradeDescriptor {
  DISTINCTION
  CREDIT
  PASS
  FAIL
}

// DoS Promotion Status - Academic Progression
enum DoSPromotionStatus {
  PROMOTED
  REPEAT
  RETAKE
  PENDING
}

// DoS Approval Status - Workflow Control
enum DoSApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  LOCKED
}

// DoS Report Card Status - Publication Control
enum DoSReportCardStatus {
  DRAFT
  APPROVED
  PUBLISHED
  LOCKED
}

// DoS Timetable Status - Schedule Management
enum DoSTimetableStatus {
  DRAFT
  APPROVED
  ACTIVE
  ARCHIVED
}

// 2. ASSESSMENT PLAN - DoS framework for continuous assessment (20%)
model DoSAssessmentPlan {
  id                  String            @id @default(auto()) @map("_id") @db.ObjectId
  schoolId            String            @db.ObjectId
  curriculumSubjectId String            @db.ObjectId
  termId              String            @db.ObjectId
  assessmentType      DoSAssessmentType
  assessmentName      String
  maxScore            Int
  weightPercentage    Float // Within the 20% CA allocation
  dueDate             DateTime
  instructions        String?
  evidenceRequired    Boolean           @default(false)
  isLocked            Boolean           @default(false)
  dosApproved         Boolean           @default(false)
  dosApprovedBy       String?           @db.ObjectId
  dosApprovedAt       DateTime?
  createdBy           String            @db.ObjectId
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  // Relations
  school            School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  curriculumSubject DoSCurriculumSubject      @relation(fields: [curriculumSubjectId], references: [id], onDelete: Cascade)
  term              Term                      @relation("DoSAssessmentPlans", fields: [termId], references: [id])
  assessments       DoSContinuousAssessment[]

  @@index([schoolId])
  @@index([curriculumSubjectId])
  @@index([termId])
  @@index([assessmentType])
  @@index([dosApproved])
  @@index([isLocked])
  @@index([dueDate])
}

// 3. CONTINUOUS ASSESSMENT - Individual CA records (20% stream)
model DoSContinuousAssessment {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId         String    @db.ObjectId
  assessmentPlanId String    @db.ObjectId
  studentId        String    @db.ObjectId
  score            Float?
  maxScore         Int
  percentage       Float? // Calculated percentage
  evidenceUrl      String? // Link to uploaded evidence
  teacherRemarks   String?
  submittedAt      DateTime?
  teacherId        String    @db.ObjectId
  isLocked         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  school         School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assessmentPlan DoSAssessmentPlan @relation(fields: [assessmentPlanId], references: [id], onDelete: Cascade)
  student        Student           @relation(fields: [studentId], references: [id])
  teacher        Staff             @relation(fields: [teacherId], references: [id])

  @@unique([assessmentPlanId, studentId])
  @@index([schoolId])
  @@index([assessmentPlanId])
  @@index([studentId])
  @@index([teacherId])
  @@index([isLocked])
}

// 4. DoS EXAM - Exam management (80% stream)
model DoSExam {
  id                  String      @id @default(auto()) @map("_id") @db.ObjectId
  schoolId            String      @db.ObjectId
  curriculumSubjectId String      @db.ObjectId
  termId              String      @db.ObjectId
  examType            DoSExamType
  examName            String
  maxScore            Int
  examDate            DateTime
  durationMinutes     Int?
  instructions        String?
  isLocked            Boolean     @default(false)
  dosApproved         Boolean     @default(false)
  dosApprovedBy       String?     @db.ObjectId
  dosApprovedAt       DateTime?
  moderationApplied   Boolean     @default(false)
  moderationFactor    Float?
  createdBy           String      @db.ObjectId
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  // Relations
  school            School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  curriculumSubject DoSCurriculumSubject @relation(fields: [curriculumSubjectId], references: [id], onDelete: Cascade)
  term              Term                 @relation(fields: [termId], references: [id])
  examResults       DoSExamResult[]

  @@index([schoolId])
  @@index([curriculumSubjectId])
  @@index([termId])
  @@index([examType])
  @@index([dosApproved])
  @@index([isLocked])
  @@index([examDate])
}

// 5. DoS EXAM RESULT - Individual exam scores (80% stream)
model DoSExamResult {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId   String   @db.ObjectId
  examId     String   @db.ObjectId
  studentId  String   @db.ObjectId
  score      Float?
  maxScore   Int
  percentage Float? // Calculated percentage
  isAbsent   Boolean  @default(false)
  enteredBy  String   @db.ObjectId
  enteredAt  DateTime
  isLocked   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  exam    DoSExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id])
  staff   Staff   @relation(fields: [enteredBy], references: [id])

  @@unique([examId, studentId])
  @@index([schoolId])
  @@index([examId])
  @@index([studentId])
  @@index([enteredBy])
  @@index([isLocked])
}

// 6. FINAL SCORE - Merged CA (20%) + Exam (80%) results (THE HEART)
model DoSFinalScore {
  id                  String              @id @default(auto()) @map("_id") @db.ObjectId
  schoolId            String              @db.ObjectId
  curriculumSubjectId String              @db.ObjectId
  studentId           String              @db.ObjectId
  termId              String              @db.ObjectId
  caScore             Float? // Continuous Assessment score (scaled to 20%)
  examScore           Float? // Exam score (scaled to 80%)
  finalScore          Float? // Total score (out of 100)
  grade               String?
  gradeDescriptor     DoSGradeDescriptor?
  teacherRemarks      String?
  dosApproved         Boolean             @default(false)
  dosApprovedBy       String?             @db.ObjectId
  dosApprovedAt       DateTime?
  isLocked            Boolean             @default(false)
  calculatedAt        DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relations
  school            School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  curriculumSubject DoSCurriculumSubject @relation(fields: [curriculumSubjectId], references: [id], onDelete: Cascade)
  student           Student              @relation(fields: [studentId], references: [id])
  term              Term                 @relation(fields: [termId], references: [id])

  @@unique([curriculumSubjectId, studentId, termId])
  @@index([schoolId])
  @@index([curriculumSubjectId])
  @@index([studentId])
  @@index([termId])
  @@index([dosApproved])
  @@index([isLocked])
}

// 7. DoS REPORT CARD - Generated academic reports (VERY IMPORTANT)
// New Curriculum Report Card Template - Customizable by DoS
model ReportCardTemplate {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  name     String
  schoolId String @db.ObjectId

  // Layout Configuration
  pageSize    String @default("A4") // A4, Letter
  orientation String @default("portrait") // portrait, landscape
  margins     Json // {top, bottom, left, right}
  colors      Json // {primary, secondary, accent, text}
  fonts       Json // {header, body, sizes}

  // Field Configuration (Customizable by DoS)
  headerFields          Json // Array of enabled header fields
  studentInfoFields     Json // Array of student info fields to show
  subjectTableColumns   Json // Array of subject table columns
  showCompetencyDetails Boolean @default(true)
  showSubjectSummary    Boolean @default(true)
  showSkillsSection     Boolean @default(true)
  skillsFields          Json // Array of skills to assess
  showAttendanceSection Boolean @default(true)
  attendanceFormat      String  @default("detailed") // detailed, summary
  remarksFields         Json // Array of remarks sections
  showPromotionDecision Boolean @default(true)
  promotionFormat       String  @default("detailed") // detailed, simple
  showDosSignature      Boolean @default(true)
  showSchoolStamp       Boolean @default(true)
  showWatermark         Boolean @default(true)
  footerFields          Json // Array of footer elements

  // Competency Level Definitions (Customizable)
  competencyLevels Json // Level definitions with colors and ranges

  // Custom Labels (Multilingual Support)
  customLabels Json // Custom text/labels

  // Template Status
  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String   @db.ObjectId

  // Relations
  school      School                    @relation(fields: [schoolId], references: [id])
  reportCards NewCurriculumReportCard[]

  @@index([schoolId])
  @@index([isDefault])
  @@index([isActive])
}

// New Curriculum Report Card - Enhanced Structure
model NewCurriculumReportCard {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  studentId  String  @db.ObjectId
  termId     String  @db.ObjectId
  schoolId   String  @db.ObjectId
  templateId String? @db.ObjectId

  // Student Information (Snapshot)
  studentName     String
  admissionNumber String
  className       String
  streamName      String?
  houseName       String?
  studentPhoto    String? // Base64 or URL

  // Term Information (Snapshot)
  termName      String
  academicYear  String
  termStartDate DateTime
  termEndDate   DateTime

  // Subject Competency Assessment
  subjectAssessments Json // Array of subject assessments with CA/Exam breakdown

  // Skills & Values Assessment (Mandatory)
  skillsAndValues Json // Communication, Collaboration, Critical Thinking, Responsibility

  // Attendance Summary
  attendanceData Json // {totalDays, presentDays, absentDays, percentage}

  // Remarks Section
  subjectTeacherRemarks String?
  classTeacherRemarks   String?
  dosAcademicRemarks    String // Mandatory

  // Promotion & Transition Decision (Critical)
  promotionStatus        String // PROMOTED, PROMOTED_ON_CONDITION, RETAKE_REQUIRED, REPEAT_ADVISED
  promotionJustification String?
  promotionConditions    Json? // Array of conditions if applicable

  // Overall Summary
  overallLevel  String // Emerging, Developing, Proficient, Advanced
  position      Int?
  totalStudents Int?
  overallGrade  String?

  // DoS Authority & Validation
  dosName       String
  dosSignature  String? // Base64 or URL
  schoolStamp   String? // Base64 or URL
  reportVersion String  @default("1.0")

  // Status & Control
  status        DoSReportCardStatus @default(DRAFT)
  dosApproved   Boolean             @default(false)
  dosApprovedBy String?             @db.ObjectId
  dosApprovedAt DateTime?
  isLocked      Boolean             @default(false)

  // Publication
  pdfUrl      String? // Generated PDF URL
  watermarked Boolean   @default(true)
  publishedAt DateTime?
  publishedBy String?   @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  student  Student             @relation(fields: [studentId], references: [id])
  term     Term                @relation(fields: [termId], references: [id])
  school   School              @relation(fields: [schoolId], references: [id])
  template ReportCardTemplate? @relation(fields: [templateId], references: [id])

  @@unique([studentId, termId])
  @@index([studentId])
  @@index([termId])
  @@index([schoolId])
  @@index([status])
  @@index([dosApproved])
  @@index([publishedAt])
}

// Legacy DoS Report Card (for backward compatibility)
model DoSReportCard {
  id                      String              @id @default(auto()) @map("_id") @db.ObjectId
  studentId               String              @db.ObjectId
  termId                  String              @db.ObjectId
  schoolId                String              @db.ObjectId
  // Snapshot data for immutability
  studentName             String
  admissionNumber         String
  className               String
  streamName              String?
  termName                String
  academicYear            String
  // Academic summary
  totalMarks              Float
  averageScore            Float
  position                Int?
  totalStudents           Int?
  overallGrade            String?
  // Comments and remarks
  classTeacherRemarks     String?
  dosAcademicComment      String?
  headTeacherRemarks      String?
  // Promotion and attendance
  promotionRecommendation DoSPromotionStatus?
  attendanceSummary       Json? // Attendance statistics
  // DoS control
  status                  DoSReportCardStatus @default(DRAFT)
  dosApproved             Boolean             @default(false)
  dosApprovedBy           String?             @db.ObjectId
  dosApprovedAt           DateTime?
  isLocked                Boolean             @default(false)
  // Publication
  pdfUrl                  String? // Generated PDF URL
  watermarked             Boolean             @default(true)
  publishedAt             DateTime?
  publishedBy             String?             @db.ObjectId
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  // Relations
  student Student @relation(fields: [studentId], references: [id])
  term    Term    @relation(fields: [termId], references: [id])

  @@unique([studentId, termId])
  @@index([studentId])
  @@index([termId])
  @@index([schoolId])
  @@index([status])
  @@index([dosApproved])
  @@index([publishedAt])
}

// Report History - Track generated reports
model ReportHistory {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId        String   @db.ObjectId
  reportType      String // 'ca-only', 'exam-only', 'final'
  classId         String   @db.ObjectId
  subjectId       String?  @db.ObjectId
  termId          String   @db.ObjectId
  studentId       String   @db.ObjectId
  generatedBy     String   @db.ObjectId
  generatedAt     DateTime @default(now())
  pdfUrl          String? // URL to stored PDF
  isDraft         Boolean  @default(false)
  reportData      Json // Snapshot of report data
  downloadCount   Int      @default(0)
  lastDownloadAt  DateTime?
  
  // Relations
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id])
  subject Subject? @relation(fields: [subjectId], references: [id])
  term    Term    @relation(fields: [termId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  
  @@index([schoolId])
  @@index([classId])
  @@index([termId])
  @@index([studentId])
  @@index([generatedBy])
  @@index([generatedAt])
}

// Report Remarks - Store teacher/DoS/Head remarks
model ReportRemark {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId    String   @db.ObjectId
  studentId   String   @db.ObjectId
  termId      String   @db.ObjectId
  remarkType  String // 'class_teacher', 'dos', 'head_teacher'
  remarkText  String
  createdBy   String   @db.ObjectId
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id])
  term    Term    @relation(fields: [termId], references: [id])
  
  @@unique([studentId, termId, remarkType])
  @@index([schoolId])
  @@index([studentId])
  @@index([termId])
}

// 7. TIMETABLE CONFIGURATION - School-wide timetable rules
model TimetableConfiguration {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId              String   @unique @db.ObjectId
  startTime             String   // "08:00" - School start time
  endTime               String   // "16:00" - School end time
  periodDurationMinutes Int      // 45 - Duration of each period
  specialPeriods        Json     // Array of {name, startTime, endTime, daysOfWeek[]}
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

// 8. DoS TIMETABLE - Schedule management
model DoSTimetable {
  id            String             @id @default(auto()) @map("_id") @db.ObjectId
  schoolId      String             @db.ObjectId
  classId       String?            @db.ObjectId // Optional: null = school-wide timetable
  termId        String             @db.ObjectId
  timetableName String
  weekCount     Int                @default(1)
  status        DoSTimetableStatus @default(DRAFT)
  dosApproved   Boolean            @default(false)
  dosApprovedBy String?            @db.ObjectId
  dosApprovedAt DateTime?
  isLocked      Boolean            @default(false)
  isTimeBased   Boolean            @default(false) // true = time-based, false = period-based (legacy)
  isArchived    Boolean            @default(false) // true = archived (read-only), false = active
  isSchoolWide  Boolean            @default(false) // true = school-wide (all classes), false = single class
  createdBy     String             @db.ObjectId
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // Relations
  school  School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class   Class?              @relation(fields: [classId], references: [id])
  term    Term                @relation(fields: [termId], references: [id])
  entries DoSTimetableEntry[]

  @@index([schoolId])
  @@index([classId])
  @@index([termId])
  @@index([status])
  @@index([dosApproved])
  @@index([isTimeBased])
  @@index([isArchived])
  @@index([isSchoolWide])
}

// 9. DoS TIMETABLE ENTRY - Individual timetable slots
model DoSTimetableEntry {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId            String   @db.ObjectId
  timetableId         String   @db.ObjectId
  classId             String?  @db.ObjectId // For school-wide timetables: which class this entry belongs to
  streamId            String?  @db.ObjectId // For school-wide timetables: which stream this entry belongs to
  curriculumSubjectId String   @db.ObjectId
  teacherId           String   @db.ObjectId
  dayOfWeek           Int // 1-7 (Monday-Sunday)
  period              Int // Period number (for legacy period-based timetables)
  
  // Time-based fields (for new time-based timetables)
  startTime           String? // "08:00"
  endTime             String? // "08:45"
  isSpecialPeriod     Boolean  @default(false)
  specialPeriodName   String? // "Assembly", "Break", "Lunch"
  
  room                String?
  isDoubleLesson      Boolean  @default(false)
  notes               String?
  createdAt           DateTime @default(now())

  // Relations
  school            School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timetable         DoSTimetable         @relation(fields: [timetableId], references: [id], onDelete: Cascade)
  class             Class?               @relation(fields: [classId], references: [id])
  stream            Stream?              @relation(fields: [streamId], references: [id])
  curriculumSubject DoSCurriculumSubject @relation(fields: [curriculumSubjectId], references: [id])
  teacher           Staff                @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([timetableId])
  @@index([timetableId, classId, streamId])
  @@index([timetableId, startTime])
  @@index([curriculumSubjectId])
  @@index([teacherId])
  @@index([isSpecialPeriod])
  @@index([classId])
  @@index([streamId])
}

// 10. PROMOTION DECISION - Academic progression records
model DoSPromotionDecision {
  id                   String              @id @default(auto()) @map("_id") @db.ObjectId
  studentId            String              @db.ObjectId
  termId               String              @db.ObjectId
  schoolId             String              @db.ObjectId
  currentClassId       String              @db.ObjectId
  // System calculations
  systemRecommendation DoSPromotionStatus
  coreSubjectsPassed   Int
  totalSubjectsPassed  Int
  totalSubjects        Int
  minimumPassRequired  Int
  averageScore         Float
  // DoS decision
  dosDecision          DoSPromotionStatus?
  dosOverrideReason    String?
  dosJustification     String?
  // Approval workflow
  dosApproved          Boolean             @default(false)
  dosApprovedBy        String?             @db.ObjectId
  dosApprovedAt        DateTime?
  isLocked             Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  // Relations
  student      Student @relation(fields: [studentId], references: [id])
  term         Term    @relation(fields: [termId], references: [id])
  currentClass Class   @relation(fields: [currentClassId], references: [id])

  @@unique([studentId, termId])
  @@index([studentId])
  @@index([termId])
  @@index([schoolId])
  @@index([systemRecommendation])
  @@index([dosDecision])
  @@index([dosApproved])
}

// 11. DoS AUDIT LOG - Track all DoS actions (IMMUTABLE)
model DoSAuditLog {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId      String   @db.ObjectId
  userId        String   @db.ObjectId
  userRole      Role
  action        String // APPROVE_CURRICULUM, LOCK_ASSESSMENT, GENERATE_REPORTS, etc.
  resourceType  String // DoSCurriculumSubject, DoSAssessmentPlan, DoSExam, etc.
  resourceId    String   @db.ObjectId
  resourceName  String? // Human-readable resource identifier
  previousValue Json?
  newValue      Json?
  reason        String?
  ipAddress     String?
  userAgent     String?
  timestamp     DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([resourceType])
  @@index([resourceId])
  @@index([timestamp])
  @@index([action])
}

// 12. DoS APPROVAL - Track approvals of subject results
model DosApproval {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  schoolId     String    @db.ObjectId
  classId      String    @db.ObjectId
  subjectId    String    @db.ObjectId
  caApproved   Boolean   @default(false)
  examApproved Boolean   @default(false)
  locked       Boolean   @default(false)
  lockedBy     String    @db.ObjectId
  lockedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
  @@index([schoolId])
  @@index([classId])
  @@index([subjectId])
  @@index([locked])
}

// 12. DoS ANALYTICS - Continuous assessment and exam performance monitoring
model DoSAnalytics {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  schoolId               String   @db.ObjectId
  termId                 String   @db.ObjectId
  classId                String?  @db.ObjectId
  subjectId              String?  @db.ObjectId
  // Assessment completion tracking
  totalAssessmentPlans   Int      @default(0)
  completedAssessments   Int      @default(0)
  pendingAssessments     Int      @default(0)
  overDueAssessments     Int      @default(0)
  // Exam completion tracking
  totalExams             Int      @default(0)
  completedExams         Int      @default(0)
  pendingExams           Int      @default(0)
  // Teacher performance
  teachersUnderAssessing Int      @default(0)
  teachersOverAssessing  Int      @default(0)
  // Academic performance
  averageCAScore         Float?
  averageExamScore       Float?
  averageFinalScore      Float?
  passRate               Float?
  // DoS workflow
  pendingApprovals       Int      @default(0)
  lockedRecords          Int      @default(0)
  generatedReports       Int      @default(0)
  calculatedAt           DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([schoolId, termId, classId, subjectId])
  @@index([schoolId])
  @@index([termId])
  @@index([classId])
  @@index([subjectId])
  @@index([calculatedAt])
}

