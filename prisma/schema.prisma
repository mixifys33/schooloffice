// Teacher Constraints - Prevents burnout and clashes
model TeacherConstraint {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId  String @db.ObjectId
  teacherId String @db.ObjectId

  // Workload limits
  maxPeriodsPerDay  Int @default(6)
  maxPeriodsPerWeek Int @default(25)

  // Availability constraints
  unavailableDays    Json @default("[]") // [1, 6] for Monday, Saturday
  unavailablePeriods Json @default("[]") // [{"day": 1, "periods": [1,2]}]

  // Teaching preferences
  preferredSubjects       Json    @default("[]") // Subject IDs
  canTeachMultipleClasses Boolean @default(true)

  // Special constraints
  requiresLab            Boolean @default(false)
  cannotTeachConsecutive Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school  School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher Staff  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([schoolId, teacherId])
  @@index([schoolId])
  @@index([teacherId])
  @@map("teacher_constraints")
}

// Room - Physical spaces with constraints
model Room {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String  @db.ObjectId
  name     String // "Physics Lab", "S1 Blue Classroom"
  code     String? // "PL1", "S1B"
  capacity Int     @default(40)
  roomType String  @default("CLASSROOM") // CLASSROOM, LAB, HALL, LIBRARY

  // Equipment and features
  hasProjector Boolean @default(false)
  hasComputers Boolean @default(false)
  hasLab       Boolean @default(false)

  // Availability
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  roomConstraints RoomConstraint[]
  timetableSlots  TimetableSlot[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([roomType])
  @@index([isActive])
}

// Room Constraints - Lab requirements, capacity, etc.
model RoomConstraint {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  schoolId String @db.ObjectId
  roomId   String @db.ObjectId

  // Room details
  roomName String
  roomType RoomType
  capacity Int

  // Subject restrictions
  allowedSubjects  Json @default("[]") // Subject IDs that can use this room
  requiredSubjects Json @default("[]") // Subject IDs that MUST use this room

  // Availability
  unavailableDays    Json @default("[]") // Days when room is not available
  unavailablePeriods Json @default("[]") // Specific periods when unavailable

  // Equipment
  hasProjector Boolean @default(false)
  hasLab       Boolean @default(false)
  hasComputers Boolean @default(false)

